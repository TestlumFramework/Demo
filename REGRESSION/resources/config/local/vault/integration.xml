<integrations xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xmlns="http://www.knubisoft.com/testlum/testing/model/global-config"
              xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/global-config global-config.xsd">

    <apis>
        <api alias="MEGA_APP" url="http://localhost:8080/api/v1" enabled="true">
            <auth authStrategy="jwt"/>
        </api>
        <api alias="MEGA_APP_BASIC" url="http://localhost:8080/api/v1" enabled="true">
            <auth authStrategy="basic"/>
        </api>
        <api alias="CAT_FACTS" url="https://catfact.ninja/" enabled="true"/>
        <api alias="MULTIPART" url="https://postman-echo.com" enabled="true"/>
    </apis>

    <websockets>
        <api alias="MEGA_WS_APP" url="ws://localhost:8080/api/v1/ws-app" protocol="stomp" enabled="true"/>
        <api alias="ECHO" url="wss://ws.postman-echo.com/raw" protocol="standard" enabled="true"/>
    </websockets>

    <graphqlIntegration>
        <api alias="MEGA_GQL_APP" url="http://localhost:8080/api/v1" enabled="true"/>
    </graphqlIntegration>

    <lambdaIntegration>
        <lambda alias="LAMBDA" enabled="true">
            <region>{{secret/data/lambda/region.key}}</region>
            <endpoint>http://localhost:4566</endpoint>
            <accessKeyId>{{secret/data/lambda/accessKey.key}}</accessKeyId>
            <secretAccessKey>{{secret/data/lambda/secretKey.key}}</secretAccessKey>
        </lambda>
    </lambdaIntegration>

    <dynamoIntegration>
        <dynamo alias="DYNAMO_0" enabled="true" truncate="true">
            <region>{{secret/data/dynamo/defaultRegion.key}}</region>
            <endpoint>http://localhost:8100</endpoint>
            <accessKeyId>{{secret/data/dynamo/accessKeyId.key}}</accessKeyId>
            <secretAccessKey>{{secret/data/dynamo/secretKeyId.key}}</secretAccessKey>
            <sessionToken>DEFAULT_SESSION_TOKEN</sessionToken>
        </dynamo>
    </dynamoIntegration>

    <mongoIntegration>
        <mongo alias="MONGO_0" enabled="true" truncate="true">
            <database>{{secret/data/mongo/database.key}}</database>
            <host>localhost</host>
            <port>27017</port>
            <username>{{secret/data/mongo/username.key}}</username>
            <password>{{secret/data/mongo/password.key}}</password>
        </mongo>

        <mongo alias="MONGO_BOOKS_0" enabled="true" truncate="true">
            <database>{{secret/data/mongo/graphqlDb.key}}</database>
            <host>localhost</host>
            <port>27017</port>
            <username>{{secret/data/mongo/username.key}}</username>
            <password>{{secret/data/mongo/password.key}}</password>
        </mongo>
    </mongoIntegration>

    <postgresIntegration>
        <postgres alias="POSTGRES_0" enabled="true" truncate="true">
            <jdbcDriver>org.postgresql.Driver</jdbcDriver>
            <username>{{secret/data/postgres/username.key}}</username>
            <password>{{secret/data/postgres/password.key}}</password>
            <connectionUrl>jdbc:postgresql://localhost:5434/playground_db</connectionUrl>
            <schema>public</schema>
            <hikari>
                <connectionTimeout>45000</connectionTimeout>
                <idleTimeout>60000</idleTimeout>
                <maxLifetime>180000</maxLifetime>
                <maximumPoolSize>50</maximumPoolSize>
                <minimumIdle>5</minimumIdle>
                <connectionInitSql>SELECT 1</connectionInitSql>
                <connectionTestQuery>SELECT 1</connectionTestQuery>
                <poolName>core-postgres-db-pool</poolName>
                <autoCommit>true</autoCommit>
            </hikari>
        </postgres>

        <postgres alias="POSTGRES_AUTH" enabled="true" truncate="true">
            <jdbcDriver>org.postgresql.Driver</jdbcDriver>
            <username>{{secret/data/postgresAuth/username.key}}</username>
            <password>{{secret/data/postgresAuth/password.key}}</password>
            <connectionUrl>jdbc:postgresql://localhost:5433/users_db</connectionUrl>
            <schema>public</schema>
            <hikari>
                <connectionTimeout>45000</connectionTimeout>
                <idleTimeout>60000</idleTimeout>
                <maxLifetime>180000</maxLifetime>
                <maximumPoolSize>50</maximumPoolSize>
                <minimumIdle>5</minimumIdle>
                <connectionInitSql>SELECT 1</connectionInitSql>
                <connectionTestQuery>SELECT 1</connectionTestQuery>
                <poolName>core-postgres-db-pool</poolName>
                <autoCommit>true</autoCommit>
            </hikari>
        </postgres>
    </postgresIntegration>

    <mysqlIntegration>
        <mysql alias="MYSQL_0" enabled="true" truncate="true">
            <jdbcDriver>com.mysql.cj.jdbc.Driver</jdbcDriver>
            <username>{{secret/data/mysql/user.username}}</username>
            <password>{{secret/data/mysql/password.password}}</password>
            <connectionUrl>jdbc:mysql://localhost:3306/playground_db?serverTimezone=Europe/Kyiv</connectionUrl>
            <schema>playground_db</schema>
            <hikari>
                <connectionTimeout>45000</connectionTimeout>
                <idleTimeout>60000</idleTimeout>
                <maxLifetime>180000</maxLifetime>
                <maximumPoolSize>50</maximumPoolSize>
                <minimumIdle>5</minimumIdle>
                <connectionInitSql>SELECT 1</connectionInitSql>
                <connectionTestQuery>SELECT 1</connectionTestQuery>
                <poolName>core-mysql-db-pool</poolName>
                <autoCommit>true</autoCommit>
            </hikari>
        </mysql>
    </mysqlIntegration>

    <clickhouseIntegration>
        <clickhouse alias="CLICKHOUSE_0" enabled="false" truncate="true">
            <jdbcDriver>ru.yandex.clickhouse.ClickHouseDriver</jdbcDriver>
            <username>{{secret/data/clickhouse/username.key}}</username>
            <password>{{secret/data/clickhouse/password.key}}</password>
            <connectionUrl>jdbc:clickhouse://localhost:8123/test_db</connectionUrl>
        </clickhouse>
    </clickhouseIntegration>

    <oracleIntegration>
        <oracle alias="ORACLE_0" enabled="false" truncate="true">
            <jdbcDriver>oracle.jdbc.OracleDriver</jdbcDriver>
            <username>{{secret/data/oracle/username.key}}</username>
            <password>{{secret/data/oracle/password.key}}</password>
            <connectionUrl>jdbc:oracle:thin:@localhost:1521/TESTLUM?oracle.jdbc.timezoneAsRegion=false</connectionUrl>
            <schema>TESTLUM</schema>
            <hikari>
                <connectionTimeout>45000</connectionTimeout>
                <idleTimeout>60000</idleTimeout>
                <maxLifetime>180000</maxLifetime>
                <maximumPoolSize>50</maximumPoolSize>
                <minimumIdle>5</minimumIdle>
                <connectionInitSql>SELECT 1 FROM dual</connectionInitSql>
                <connectionTestQuery>SELECT 1 FROM dual</connectionTestQuery>
                <poolName>core-oracle-db-pool</poolName>
                <autoCommit>true</autoCommit>
            </hikari>
        </oracle>
    </oracleIntegration>

    <redisIntegration>
        <redis alias="REDIS_0" enabled="true" truncate="true">
            <host>localhost</host>
            <port>6379</port>
        </redis>
    </redisIntegration>

    <kafkaIntegration>
        <kafka alias="KAFKA_0" enabled="true" truncate="true">
            <bootstrapAddress>localhost:9094</bootstrapAddress>
            <autoOffsetReset>earliest</autoOffsetReset>
            <maxPollRecords>100</maxPollRecords>
            <maxPollIntervalMs>1000</maxPollIntervalMs>
            <clientId>client-queue</clientId>
            <groupId>group-queue</groupId>
            <autoCommitTimeout>2000</autoCommitTimeout>
        </kafka>
        <kafka alias="KAFKA_WITH_LATEST_AUTO_OFFSET"
               enabled="true"
               truncate="true">
            <bootstrapAddress>localhost:9094</bootstrapAddress>
            <autoOffsetReset>latest</autoOffsetReset>
            <maxPollRecords>2</maxPollRecords>
            <maxPollIntervalMs>1000</maxPollIntervalMs>
            <clientId>client-latest</clientId>
            <groupId>group-latest</groupId>
            <autoCommitTimeout>2000</autoCommitTimeout>
        </kafka>
        <kafka alias="KAFKA_WITH_REDUCED_POLL_RECORDS"
               enabled="true"
               truncate="true">
            <bootstrapAddress>localhost:9094</bootstrapAddress>
            <autoOffsetReset>earliest</autoOffsetReset>
            <maxPollRecords>2</maxPollRecords>
            <maxPollIntervalMs>5000</maxPollIntervalMs>
            <clientId>client-reduced</clientId>
            <groupId>group-reduced</groupId>
            <autoCommitTimeout>2000</autoCommitTimeout>
        </kafka>
    </kafkaIntegration>

    <rabbitmqIntegration>
        <rabbitmq alias="RABBIT_0" enabled="true" truncate="true">
            <host>localhost</host>
            <port>5672</port>
            <username>{{secret/data/rabbit/username.key}}</username>
            <password>{{secret/data/rabbit/password.key}}</password>
            <apiPort>15672</apiPort>
            <virtualHost>/</virtualHost>
            <enabledMetrics>true</enabledMetrics>
        </rabbitmq>
    </rabbitmqIntegration>

    <sqsIntegration>
        <sqs alias="SQS_0" enabled="true" truncate="true">
            <region>{{secret/data/lambda/region.key}}</region>
            <endpoint>http://localhost:4566</endpoint>
            <accessKeyId>{{secret/data/lambda/accessKey.key}}</accessKeyId>
            <secretAccessKey>{{secret/data/lambda/secretKey.key}}</secretAccessKey>
        </sqs>
    </sqsIntegration>

    <elasticsearchIntegration>
        <elasticsearch alias="ELASTIC_0" enabled="false" truncate="true">
            <host>localhost</host>
            <port>9200</port>
            <scheme>http</scheme>
            <connectionTimeout>30000</connectionTimeout>
            <socketTimeout>30000</socketTimeout>
            <signer>false</signer>
            <serviceName>DISABLED</serviceName>
            <region>DISABLED</region>
            <username>elastic</username>
            <password>q98374fkjdkfuyqiweysdc</password>
        </elasticsearch>
    </elasticsearchIntegration>

    <s3Integration>
        <s3 alias="S3_0" enabled="true" truncate="true">
            <region>{{secret/data/lambda/region.key}}</region>
            <endpoint>http://localhost:4566</endpoint>
            <accessKeyId>{{secret/data/lambda/accessKey.key}}</accessKeyId>
            <secretAccessKey>{{secret/data/lambda/secretKey.key}}</secretAccessKey>
        </s3>
    </s3Integration>

    <sendgridIntegration>
        <sendgrid alias="SG_0" enabled="false">
            <apiKey>*****************************</apiKey>
        </sendgrid>
    </sendgridIntegration>

    <twilioIntegration>
        <twilio alias="TWILIO_0" enabled="false">
            <accountSid>*****************************</accountSid>
            <authToken>*****************************</authToken>
            <twilioNumber>+10000000000</twilioNumber>
        </twilio>
    </twilioIntegration>

    <smtpIntegration>
        <smtp alias="SMTP_0" enabled="false">
            <host>smtp.gmail.com</host>
            <port>587</port>
            <username>*****************************</username>
            <password>*****************************</password>
            <smtpAuth>true</smtpAuth>
            <smtpStarttlsEnable>true</smtpStarttlsEnable>
        </smtp>
    </smtpIntegration>

    <sesIntegration>
        <ses alias="SES_0" enabled="true">
            <region>{{secret/data/lambda/region.key}}</region>
            <endpoint>http://localhost:4566</endpoint>
            <accessKeyId>{{secret/data/lambda/accessKey.key}}</accessKeyId>
            <secretAccessKey>{{secret/data/lambda/secretKey.key}}</secretAccessKey>
        </ses>
    </sesIntegration>
</integrations>
