<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Demonstration of Web Socket test</description>
        <name>Web Socket</name>
    </overview>

    <settings>
        <tags>websocket</tags>
    </settings>

    <websocket comment="Connect to stomp websocket API" alias="MEGA_WS_APP"
               disconnect="true">
        <stomp>
            <subscribe comment="Check ability to subscribe to the 'server' topic"
                       topic="/topic/server"/>

            <receive comment="Check ability to receive periodic message from the server"
                     topic="/topic/server"
                     limit="1" timeoutMillis="1000">
                <message>[ "server periodic message" ]</message>
            </receive>
        </stomp>
    </websocket>

    <websocket comment="Connect to stomp websocket API again because previous session must be closed"
               alias="MEGA_WS_APP"
               disconnect="false">
        <stomp>
            <receive comment="Check disability to receive periodic message from the server after disconnecting"
                     topic="/topic/server"
                     limit="1">
                <file>expected_5.json</file>
            </receive>

            <subscribe comment="Check ability to subscribe to 'Ping' topic"
                       topic="/topic/ping"/>

            <send comment="Check ability to send 'Ping' message"
                  endpoint="/app/ping">
                <message>ping message</message>
            </send>

            <subscribe comment="Check ability to subscribe to 'test' topic"
                       topic="/topic/test"/>

            <send comment="Check ability to send json message"
                  endpoint="/app/test">
                <file>body_9.json</file>
            </send>

            <subscribe comment="Check ability to subscribe to the 'server' topic"
                       topic="/topic/server"/>
        </stomp>
    </websocket>

    <websocket comment="Connect to websocket API" alias="ECHO">

        <send comment="Check ability to send 'subscription' message">
            <message>
                {
                "event": "subscribe",
                "pair": [
                "XBT/USD",
                "XBT/EUR"
                ],
                "subscription": {
                "name": "ticker"
                }
                }
            </message>
        </send>

        <receive comment="Check ability to receive response from the subscription"
                 limit="1" timeoutMillis="1000">
            <file>expected_14.json</file>
        </receive>
    </websocket>

    <http comment="Some api request to check websocket is not disconnected"
          alias="CAT_FACTS">
        <get endpoint="/facts">
            <response file="expected_15.json" code="200"/>
        </get>
    </http>

    <websocket comment="Checking that all subscriptions still be active"
               alias="MEGA_WS_APP"
               disconnect="true">
        <stomp>
            <receive comment="Check ability to receive 'Pong' message"
                     topic="/topic/ping"
                     limit="1">
                <message>
                    [
                    {
                    "value": "ping message"
                    }
                    ]
                </message>
            </receive>

            <receive comment="Check ability to receive json response"
                     topic="/topic/test"
                     limit="2" timeoutMillis="3000">
                <file>expected_18.json</file>
            </receive>

            <receive comment="Check ability to receive periodic message from the server"
                     topic="/topic/server"
                     limit="3" timeoutMillis="4000">
                <file>expected_19.json</file>
            </receive>
        </stomp>
    </websocket>

</scenario>
