<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Self test for migrate command</description>
        <name>Migrate self test</name>
        <developer>Kamaletdinov Anatoliy</developer>
    </overview>

    <settings active="false" truncateStorages="true">
        <tags>migrate-self</tags>
    </settings>

    <migrate comment="Migrate Postgres dataset" alias="POSTGRES_0">
        <dataset>postgres_patch.sql</dataset>
    </migrate>

    <migrate comment="Migrate NEWS data to Oracle"
             alias="ORACLE_0" name="ORACLE">
        <dataset>oracle_patch.sql</dataset>
    </migrate>

    <migrate comment="Migrate single dataset to MySQL"
             alias="MYSQL_0" name="MYSQL">
        <dataset>mysql_patch.sql</dataset>
    </migrate>

    <migrate comment="Migrate NEWS data to ClickHouse"
             alias="CLICKHOUSE_0" name="CLICKHOUSE">
        <dataset>clickhouse_patch.sql</dataset>
    </migrate>

    <migrate comment="Migrate NEWS data to MongoDB" alias="MONGO_0" name="MONGODB">
        <dataset>mongo_patch.bson</dataset>
    </migrate>

    <postgres comment="Check ability to get Postgres data"
              alias="POSTGRES_0"
              file="expected_6.json">
        <query>
            SELECT newsnumber
            FROM news
            WHERE newsname = 'News2'
        </query>
    </postgres>

    <oracle comment="Check NEWS data migration from Oracle DB"
            alias="ORACLE_0"
            file="expected_7.json">
        <query>
            SELECT NEWSNAME
            FROM NEWS
            WHERE NEWSNUMBER = 38005238
        </query>
    </oracle>

    <mysql comment="Check ability to get mySQL data"
           alias="MYSQL_0"
           file="expected_8.json">
        <query>
            SELECT newsname
            FROM news
            WHERE id = 3
        </query>
    </mysql>

    <clickhouse comment="Check ability to get ClickHouse data"
                alias="CLICKHOUSE_0"
                file="expected_9.json">
        <query>
            SELECT newsNumber
            FROM news
            WHERE newsName = 'Brazil'
        </query>
    </clickhouse>

    <mongo comment="Check ability to get MongoDB data"
           alias="MONGO_0"
           file="expected_10.json">
        <query>
            {
            find: "mongo_news",
            filter: {
            active: true,
            number: { "$eq": 17 }
            } }
        </query>
    </mongo>

    <migrate comment="Check ability to migrate test dataset to DynamoDB"
             alias="DYNAMO_0" name="DYNAMO">
        <dataset>dynamo_patch.partiql</dataset>
    </migrate>

    <dynamo comment="Check ability to get new DynamoDB data"
            alias="DYNAMO_0"
            file="expected_12.json">
        <query>
            SELECT *
            FROM dynamodb_news
            WHERE name = 'News1';
        </query>
    </dynamo>

