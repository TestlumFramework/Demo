<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>DynamoDB Test with variables</description>
        <name>DynamoDB Variables Test</name>
    </overview>

    <settings truncateStorages="true">
        <tags>dynamodb</tags>
    </settings>

    <var comment="Variable with expected 3 file"
         name="expected_3">
        <constant value="expected_3"/>
    </var>

    <var comment="Variable with news id"
         name="id">
        <constant value="10"/>
    </var>

    <dynamo alias="DYNAMO_0"
            comment="Clear previous data for the current ID"
            file="{{expected_3}}.json">
        <query>
            DELETE FROM dynamodb_news
            WHERE id = '{{id}}'
        </query>
    </dynamo>

    <var comment="Variable with expected 7 file"
         name="expected_7">
        <constant value="expected_7"/>
    </var>

    <var comment="Variable with news name"
         name="name">
        <constant value="Dynamic PartiQL News"/>
    </var>

    <var comment="Variable with news number"
         name="number">
        <constant value="10"/>
    </var>

    <dynamo alias="DYNAMO_0"
            comment="Insert dynamic data to table for news id {{id}}"
            file="{{expected_7}}.json">
        <query>
            INSERT INTO dynamodb_news VALUE {
            'id': '{{id}}',
            'name': '{{name}}',
            'number': {{number}},
            'active': true,
            'createdAt': '2026-04-15T12:00:00.000'
            }
        </query>
    </dynamo>

    <dynamo alias="DYNAMO_0"
            comment="Read data from table using variables"
            file="expected_8.json">
        <query>
            SELECT * FROM dynamodb_news
            WHERE id = '{{id}}'
        </query>
    </dynamo>

    <dynamo alias="DYNAMO_0"
            comment="Clean up data after test"
            file="expected_9.json">
        <query>
            DELETE FROM dynamodb_news
            WHERE id = '{{id}}'
        </query>
    </dynamo>

</scenario>