<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>DynamoDB Repeat with variations and atomic counter (Single Table)</description>
        <name>DynamoDB Repeat Variations Test</name>
    </overview>

    <settings truncateStorages="true">
        <tags>dynamo</tags>
    </settings>

    <dynamo alias="DYNAMO_0"
            comment="Clean up temporary records for repeat test"
            file="expected_1.json">
        <query>DELETE FROM dynamodb_news WHERE id = '10'</query>
        <query>DELETE FROM dynamodb_news WHERE id = '20'</query>
        <query>DELETE FROM dynamodb_news WHERE id = '30'</query>
    </dynamo>

    <dynamo alias="DYNAMO_0"
            comment="Insert static data for the loop to read"
            file="expected_2.json">
        <query>
            INSERT INTO dynamodb_news VALUE {
            'id': '10',
            'name': 'Global Tech Update',
            'number': 10,
            'active': true
            }
        </query>
        <query>
            INSERT INTO dynamodb_news VALUE {
            'id': '20',
            'name': 'Local Sports Events',
            'number': 20,
            'active': true
            }
        </query>
        <query>
            INSERT INTO dynamodb_news VALUE {
            'id': '30',
            'name': 'Weather Forecast 2026',
            'number': 30,
            'active': false
            }
        </query>
    </dynamo>

    <repeat comment="Run variations locally in repeat"
            variations="dynamo_repeat_data.csv">
        <dynamo alias="DYNAMO_0"
                comment="Check ability to get specific news inside repeat loop"
                file="{{expected_4}}.json">
            <query>SELECT * FROM dynamodb_news WHERE id = '{{id}}'</query>
        </dynamo>
    </repeat>

    <dynamo alias="DYNAMO_0"
            comment="Initialize a log counter in the same table"
            file="expected_7.json">
        <query>DELETE FROM dynamodb_news WHERE id = 'log_1'</query>
        <query>
            INSERT INTO dynamodb_news VALUE {
            'id': 'log_1',
            'name': 'LoopExecutionLog',
            'number': 0,
            'active': true
            }
        </query>
    </dynamo>

    <repeat comment="Run the update query exactly 5 times"
            times="5">
        <dynamo alias="DYNAMO_0"
                comment="Increment the counter on each iteration"
                file="expected_9.json">
            <query>UPDATE dynamodb_news SET number = number + 1 WHERE id = 'log_1'</query>
        </dynamo>
    </repeat>

    <dynamo alias="DYNAMO_0"
            comment="Verify the counter reached 5"
            file="expected_14.json">
        <query>SELECT number FROM dynamodb_news WHERE id = 'log_1'</query>
    </dynamo>

    <dynamo alias="DYNAMO_0"
            comment="Clean up all temporary items after test"
            file="expected_15.json">
        <query>DELETE FROM dynamodb_news WHERE id = '10'</query>
        <query>DELETE FROM dynamodb_news WHERE id = '20'</query>
        <query>DELETE FROM dynamodb_news WHERE id = '30'</query>
        <query>DELETE FROM dynamodb_news WHERE id = 'log_1'</query>
    </dynamo>

</scenario>