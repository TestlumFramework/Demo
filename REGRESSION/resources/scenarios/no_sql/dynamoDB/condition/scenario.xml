<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>DynamoDB conditional execution check</description>
        <name>DynamoDB Condition Test</name>
    </overview>

    <settings truncateStorages="true">
        <tags>dynamodb</tags>
    </settings>

    <dynamo alias="DYNAMO_0"
            comment="Clean up temporary item before test"
            file="expected_1.json">
        <query>
            DELETE FROM dynamodb_news
            WHERE id = '99'
        </query>
    </dynamo>

    <condition comment="True condition to insert test data into table" name="CONDITION_TRUE" spel="true"/>

    <dynamo alias="DYNAMO_0"
            comment="Insert temporary data to table"
            file="expected_3.json"
            condition="{{CONDITION_TRUE}}">
        <query>
            INSERT INTO dynamodb_news VALUE {
            'id': '99',
            'name': 'INITIAL_DATA',
            'number': 99,
            'active': true
            }
        </query>
    </dynamo>

    <dynamo alias="DYNAMO_0"
            comment="Read data from table - verify inserted data"
            file="expected_4.json">
        <query>
            SELECT * FROM dynamodb_news
            WHERE id = '99'
        </query>
    </dynamo>

    <dynamo alias="DYNAMO_0"
            comment="Attempt to delete with condition=false"
            condition="false"
            file="expected_5.json">
        <query>
            DELETE_NOT_EXIST FROM dynamodb_news
            WHERE id = '99'
        </query>
    </dynamo>

    <dynamo alias="DYNAMO_0"
            comment="Read data from table - verify data was NOT deleted"
            condition="true"
            file="expected_6.json">
        <query>
            SELECT * FROM dynamodb_news
            WHERE id = '99'
        </query>
    </dynamo>

    <dynamo alias="DYNAMO_0"
            comment="Clean up temporary item after test"
            file="expected_7.json">
        <query>
            DELETE FROM dynamodb_news
            WHERE id = '99'
        </query>
    </dynamo>

</scenario>