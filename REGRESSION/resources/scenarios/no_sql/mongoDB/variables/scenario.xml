<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>MongoDB Test with variables</description>
        <name>Mongo Variables Test</name>
    </overview>

    <settings truncateStorages="true">
        <tags>mongodb</tags>
    </settings>

    <var comment="Variable with expected 3 file name"
         name="expected_3">
        <constant value="expected_3"/>
    </var>

    <var comment="Variable with news id"
         name="id">
        <constant value="10"/>
    </var>

    <mongo alias="MONGO_0"
           comment="Clear previous data for the current ID"
           file="{{expected_3}}.json">
        <query>
            {
            "delete": "test_news",
            "deletes": [ { "q": { "_id": {{id}} }, "limit": 0 } ]
            }
        </query>
    </mongo>

    <var comment="Variable with expected 7 file name"
         name="expected_7">
        <constant value="expected_7"/>
    </var>

    <var comment="Variable with news title"
         name="title">
        <constant value="New Database Support"/>
    </var>

    <var comment="Variable with news category"
         name="category">
        <constant value="Tech"/>
    </var>

    <mongo alias="MONGO_0"
           comment="Insert dynamic data to collection for news id {{id}}"
           file="{{expected_7}}.json">
        <query>
            {
            "insert": "test_news",
            "documents": [
            {
            "_id": {{id}},
            "title": "{{title}}",
            "category": "{{category}}"
            }
            ]
            }
        </query>
    </mongo>

    <mongo alias="MONGO_0"
           comment="Read data from collection using variables"
           file="expected_8.json">
        <query>
            {
            "find": "test_news",
            "filter": { "_id": {{id}} }
            }
        </query>
    </mongo>

</scenario>