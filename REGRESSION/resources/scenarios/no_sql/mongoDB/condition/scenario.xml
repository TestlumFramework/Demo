<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>MongoDB conditional execution check</description>
        <name>Mongo Condition Test</name>
    </overview>

    <settings truncateStorages="true">
        <tags>mongodb</tags>
    </settings>

    <mongo alias="MONGO_0"
           comment="Clean up collection for condition test"
           file="expected_1.json">
        <query>
            {
            "delete": "condition_test",
            "deletes": [ { "q": {}, "limit": 0 } ]
            }
        </query>
    </mongo>

    <condition comment="True condition to insert test data" name="CONDITION_TRUE" spel="true"/>

    <mongo alias="MONGO_0"
           comment="Insert data to collection"
           file="expected_3.json"
           condition="{{CONDITION_TRUE}}">
        <query>
            {
            "insert": "condition_test",
            "documents": [
            { "_id": 99, "data_value": "INITIAL_DATA" }
            ]
            }
        </query>
    </mongo>

    <mongo alias="MONGO_0"
           comment="Read data from collection - verify inserted data"
           file="expected_4.json">
        <query>
            {
            "find": "condition_test",
            "filter": { "_id": 99 }
            }
        </query>
    </mongo>

    <mongo alias="MONGO_0"
           comment="Attempt to delete with condition=false"
           condition="false"
           file="expected_5.json">
        <query>
            {
            "DELETE_NOT_EXIST": "condition_test",
            "deletes": [ { "q": { "_id": 99 }, "limit": 1 } ]
            }
        </query>
    </mongo>

    <var comment="Variable for true condition"
         name="TRUE_VAR">
        <expression value="true"/>
    </var>
    
    <mongo alias="MONGO_0"
           comment="Read data from collection - verify data was NOT deleted"
           condition="{{TRUE_VAR}}"
           file="expected_7.json">
        <query>
            {
            "find": "condition_test",
            "filter": { "_id": 99 }
            }
        </query>
    </mongo>

</scenario>