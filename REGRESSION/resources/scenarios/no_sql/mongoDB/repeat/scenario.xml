<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>MongoDB Repeat with localized variations and fixed times</description>
        <name>Mongo Repeat Variations Test</name>
    </overview>

    <settings truncateStorages="true">
        <tags>mongo</tags>
    </settings>

    <mongo alias="MONGO_0"
           comment="Clean up repeat_news collection"
           file="expected_1.json">
        <query>
            {
            "delete": "repeat_news",
            "deletes": [ { "q": {}, "limit": 0 } ]
            }
        </query>
    </mongo>

    <mongo alias="MONGO_0"
           comment="Insert static data for the loop to read"
           file="expected_2.json">
        <query>
            {
            "insert": "repeat_news",
            "documents": [
            { "_id": 10, "title": "Global Tech Update" },
            { "_id": 20, "title": "Local Sports Events" },
            { "_id": 30, "title": "Weather Forecast 2026" }
            ]
            }
        </query>
    </mongo>

    <repeat comment="Run variations locally in repeat"
            variations="mongo_repeat_data.csv">

        <mongo alias="MONGO_0"
               comment="Check ability to get specific news inside repeat loop"
               file="{{expected_4}}.json">
            <query>
                {
                "find": "repeat_news",
                "filter": { "_id": {{id}} }
                }
            </query>
        </mongo>
    </repeat>

    <mongo alias="MONGO_0"
           comment="Clean up repeat_simple_log collection"
           file="expected_7.json">
        <query>
            {
            "delete": "repeat_simple_log",
            "deletes": [ { "q": {}, "limit": 0 } ]
            }
        </query>
    </mongo>

    <repeat comment="Run the insert query exactly 5 times"
            times="5">

        <mongo alias="MONGO_0"
               comment="Insert a log entry on each iteration"
               file="expected_9.json">
            <query>
                {
                "insert": "repeat_simple_log",
                "documents": [
                { "message": "Loop iteration executed" }
                ]
                }
            </query>
        </mongo>
    </repeat>

    <mongo alias="MONGO_0"
           comment="Verify exactly 5 rows were inserted by the loop"
           file="expected_14.json">
        <query>
            {
            "count": "repeat_simple_log"
            }
        </query>
    </mongo>

</scenario>