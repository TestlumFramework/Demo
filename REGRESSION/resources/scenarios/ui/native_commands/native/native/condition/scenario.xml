<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Functional validation of native command execution paths and conditions.</description>
        <name>Native Flow Validation</name>
    </overview>

    <settings>
        <tags>native</tags>
    </settings>

    <native comment="Executing native test sequence"
            condition="true">
        <wait comment="Waiting 1 second"
              time="1"
              unit="millis"/>
    </native>

    <native comment="Executing native test sequence"
            condition="false">
        <click comment="Clicked non-existent element"
               locator="non-exist-locator"
               locatorStrategy="xpath"/>
    </native>


</scenario>