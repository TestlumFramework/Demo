<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Iterative validation of click interactions across multiple data variations.</description>
        <name>Interactive Click Validation</name>
    </overview>

    <settings>
        <variations>variations_native_command.csv</variations>
        <tags>native</tags>
    </settings>
  
    <native comment="Executing native automation sequence">

        <click comment="Clicking on button clickPage" locator="testApp.clickPage"/>
        <click comment="Clicking on button to increase counter {{comment}}"
               condition="{{flag}}"
               locator="{{locatorClick}}"/>
        
        <assert comment="Validating expected UI state">
            <attribute comment="Retrieving element text attribute for validation"
                       locator="testApp.counter"
                       name="text">
                <content>Counter: 1</content>
            </attribute>
        </assert>
    </native>

</scenario>