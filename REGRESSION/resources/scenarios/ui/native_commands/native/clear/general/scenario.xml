<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Functional testing of input clearing operations and field state reset mechanisms.</description>
        <name>Input Field Reset Validation</name>
    </overview>

    <settings>
        <tags>native</tags>
    </settings>

    <native comment="Executing native automation sequence">
        <click comment="Clicking on button clear page" locator="testApp.clearPage"/>

        <assert comment="Validating expected UI state">
            <attribute comment="Retrieving element text attribute for validation"
                       locator="testApp.statusInput"
                       name="text">
                <content>Status: NotEmpty</content>
            </attribute>
        </assert>

        <clear comment="Clear input value" locator="testApp.clearInputText"/>

        <assert comment="Validating expected UI state">
            <attribute comment="Retrieving element text attribute for validation"
                       locator="testApp.statusInput"
                       name="text">
                <content>Status: Empty</content>
            </attribute>
        </assert>
    </native>


</scenario>