<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Test webView command - variations</description>
        <name>WebView variations</name>
    </overview>
    <settings>
        <variations>variations_native_command.csv</variations>
        <tags>native</tags>
    </settings>

    <native comment="Executing native automation sequence">
        <click comment="Navigate to WebView screen" locator="testApp.webViewPage"/>
        <wait comment="Waiting 1 second" time="1"/>

        <webView comment="WebView variations {{comment}}"
                 condition="{{flag}}">
            <assert comment="Assert initial text in variations">
                <attribute comment="Verify initial text"
                           locator="testApp.webViewText"
                           locatorStrategy="locatorId"
                           name="value">
                    <content>This is an embedded web view.</content>
                </attribute>
            </assert>
        </webView>

    </native>

</scenario>