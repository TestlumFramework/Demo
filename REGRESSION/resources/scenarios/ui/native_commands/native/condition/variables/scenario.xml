<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Test condition command - variables: SpEL uses stored var</description>
        <name>Condition variables</name>
    </overview>
    <settings>
        <tags>native</tags>
    </settings>

    <native comment="Executing native automation sequence">
        <click comment="Navigate to Click screen" locator="testApp.clickPage"/>
        <click comment="Reset counter" locator="testApp.resetClick"/>
        <var comment="Store threshold value"
             name="threshold">
            <constant value="5"/>
        </var>

        <condition comment="Check if threshold &gt; 3 (true)"
                   name="aboveThreshold"
                   spel="{{threshold}} &gt; 3"/>

        <click comment="Click executes (threshold &gt; 3)"
               condition="{{aboveThreshold}}"
               locator="testApp.clickButton"/>
        
        <assert comment="Assert counter is 1">
            <attribute comment="Check counter text"
                       locator="testApp.counter"
                       locatorStrategy="locatorId"
                       name="text">
                <content>Counter: 1</content>
            </attribute>
        </assert>

        <condition comment="Check if threshold &gt; 10 (false)"
                   name="aboveTen"
                   spel="{{threshold}} &gt; 10"/>

        <click comment="Click skipped (threshold not &gt; 10)"
               condition="{{aboveTen}}"
               locator="testApp.clickButton"/>
        <assert comment="Assert counter is 1">
            <attribute comment="Check counter text"
                       locator="testApp.counter"
                       locatorStrategy="locatorId"
                       name="text">
                <content>Counter: 1</content>
            </attribute>
        </assert>
    </native>

</scenario>