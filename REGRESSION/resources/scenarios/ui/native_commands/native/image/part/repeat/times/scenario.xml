<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Testing image part tag with repeat (times)</description>
        <name>Image part repeat times</name>
    </overview>

    <settings>
        <tags>native</tags>
    </settings>

    <native comment="Executing native automation sequence">

        <click comment="Clicking on button imagePage" locator="testApp.imagePage"/>

        <repeat comment="Repeat 3 times"
                times="3">
            <image comment="Test image part"
                   file="test_image.png">
                <part locator="testApp.image" locatorStrategy="locatorId"/>
            </image>
        </repeat>

    </native>

</scenario>