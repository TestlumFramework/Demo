<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Testing image fullscreen tag with repeat (times)</description>
        <name>Image fullscreen repeat times</name>
    </overview>

    <settings>
        <tags>native</tags>
    </settings>

    <native comment="Executing native automation sequence">

        <click comment="Clicking on button imagePage" locator="testApp.imagePage"/>

        <wait comment="Waiting 1 second" time="1"/>

        <repeat comment="Repeat 3 times"
                times="3">
            <image comment="Test image fullscreen"
                   file="test_image.png">
                <fullScreen/>
            </image>
        </repeat>

    </native>

</scenario>