<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Testing image fullscreen command with condition</description>
        <name>Image fullscreen condition</name>
    </overview>

    <settings>
        <tags>native</tags>
    </settings>

    <native comment="Executing native automation sequence">

        <click comment="Clicking on button imagePage" locator="testApp.imagePage"/>

        <wait comment="Waiting 1 second" time="1"/>

        <image comment="Test image fullscreen with condition true"
               condition="true"
               file="test_image.png">
            <fullScreen/>
        </image>
               
        <image comment="Test image fullscreen with condition false"
               condition="false"
               file="non_existed_image.png">
            <fullScreen/>
        </image>

    </native>

</scenario>