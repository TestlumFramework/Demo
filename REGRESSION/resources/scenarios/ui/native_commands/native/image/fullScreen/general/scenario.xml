<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>General test image fullscreen command</description>
        <name>Image fullscreen command</name>
    </overview>

    <settings>
        <tags>native</tags>
    </settings>

    <native comment="Executing native automation sequence">
        <click comment="Clicking on button imagePage" locator="testApp.imagePage"/>

        <wait comment="Waiting 1 second" time="1"/>

        <image comment="Test general fullscreen image command"
               file="test_image.png">
            <fullScreen/>
        </image>

    </native>

</scenario>