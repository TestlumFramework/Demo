<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Test swipe element - repeat variations</description>
        <name>Swipe element repeat variations</name>
    </overview>

    <settings>
        <variations>variations_native_command.csv</variations>
        <tags>native</tags>
    </settings>

    <native comment="Test native swipe element command">

        <click comment="Navigate to Swipe screen" locator="testApp.swipePage"/>
        <click comment="Reset state before test" locator="testApp.resetButtonSwipe"/>
        <click comment="Activate element mode" locator="testApp.enableElementMode"/>

        <repeat comment="Repeat swipe across CSV rows"
                variations="variations_native_command.csv">
            <swipeNative comment="Swipe element {{comment}}"
                         condition="{{flag}}">
                <element comment="CSV driven swipe"
                         direction="right"
                         locator="{{locatorSwipeElement}}"
                         percent="80"/>
            </swipeNative>
        </repeat>

        <assert comment="Verify element swipe count">
            <attribute comment="Check element counter text"
                       locator="testApp.swipeElementCounter"
                       locatorStrategy="locatorId"
                       name="text">
                <content>Element swipes: 2</content>
            </attribute>
        </assert>

    </native>

</scenario>