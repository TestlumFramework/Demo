<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Test swipe page - repeat times</description>
        <name>Swipe page repeat times</name>
    </overview>

    <settings>
        <tags>native</tags>
    </settings>

    <native comment="Test native swipe page command">

        <click comment="Navigate to Swipe screen" locator="testApp.swipePage"/>
        <click comment="Reset state before test" locator="testApp.resetButtonSwipe"/>
        <click comment="Activate page mode" locator="testApp.enablePageMode"/>

        <repeat comment="Repeat page swipe 3 times"
                times="3">
            <swipeNative comment="Page swipe in repeat">
                <page comment="Repeat full screen swipe"
                      direction="right"
                      percent="80"/>
            </swipeNative>
        </repeat>
        <assert comment="Verify page swipe count">
            <attribute comment="Check page counter text"
                       locator="testApp.swipePageCounter"
                       locatorStrategy="locatorId"
                       name="text">
                <content>Page swipes: 3</content>
            </attribute>
        </assert>
    </native>

</scenario>