<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Verification of UI refresh operations and content reloading across multiple scenarios.</description>
        <name>Screen Content Refresh</name>
    </overview>

    <settings>
        <variations>variations_native_command.csv</variations>
        <tags>native</tags>
    </settings>

    <native comment="Executing native automation sequence">
        <click comment="Navigate to Refresh screen" locator="testApp.refreshPage"/>

        <refresh comment="Test refresh {comment}" condition="{{flag}}"/>
        <assert comment="Verify refresh execution">
            <attribute comment="Retrieving element text attribute for validation"
                       locator="testApp.refreshCount"
                       locatorStrategy="locatorId"
                       name="text">
                <content>1</content>
            </attribute>
        </assert>
    </native>

</scenario>