<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Test assert attribute - variations: condition from CSV</description>
        <name>Assert attribute variations</name>
    </overview>
    <settings>
        <variations>variations_native_command.csv</variations>
        <tags>native</tags>
    </settings>

    <native comment="Executing native automation sequence">
        <click comment="Navigate to Click screen" locator="testApp.clickPage"/>
        <click comment="Reset counter" locator="testApp.resetClick"/>
        <assert comment="Assert attribute in variation {{comment}}"
                condition="{{flag}}">
            <attribute comment="Check counter text in CSV row"
                       locator="testApp.counter"
                       locatorStrategy="locatorId"
                       name="text">
                <content>{{assertContent}}</content>
            </attribute>
        </assert>
    </native>

</scenario>