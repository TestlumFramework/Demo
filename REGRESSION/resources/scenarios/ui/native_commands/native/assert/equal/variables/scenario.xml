<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Test assert equal - variables: two vars compared</description>
        <name>Assert equal variables</name>
    </overview>
    <settings>
        <tags>native</tags>
    </settings>

    <native comment="Executing native automation sequence">
        <click comment="Navigate to Var screen" locator="testApp.varPage"/>
        <var comment="Store first value"
             name="var1">
            <constant value="Testlum"/>
        </var>
        <var comment="Store second value - same"
             name="var2">
            <constant value="Testlum"/>
        </var>

        <assert comment="Assert two variables are equal">
            <equal comment="val1 and val2 both equal Testlum">
                <content>{{var1}}</content>
                <content>{{var2}}</content>
            </equal>
        </assert>
    </native>

</scenario>