<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Test assert equal - variations: condition from CSV</description>
        <name>Assert equal variations</name>
    </overview>
    <settings>
        <variations>variations_native_command.csv</variations>
        <tags>native</tags>
    </settings>

    <native comment="Executing native automation sequence">
        <click comment="Navigate to Var screen" locator="testApp.varPage"/>

        <assert comment="Assert equal in variation {{comment}}"
                condition="{{flag}}">
            <equal comment="Variable matches constant">
                <content>{{flag}}</content>
                <content>true</content>
            </equal>
        </assert>
    </native>

</scenario>