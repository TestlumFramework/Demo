<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Testing input command with variables</description>
        <name>Input variables test</name>
    </overview>

    <settings>
        <tags>native</tags>
    </settings>

    <native comment="Executing native automation sequence">

        <click comment="Clicking on button inputPage" locator="testApp.inputPage"/>

        <var comment="Variable locator"
             name="locInput">
            <constant value="testApp.inputArea"/>
        </var>
        
        <var comment="Variable value"
             name="inputValue">
            <constant value="Test"/>
        </var>

        <input comment="Run input command"
               locator="{{locInput}}"
               locatorStrategy="locatorId"
               value="{{inputValue}}"/>

        <assert comment="Validating expected UI state">
            <attribute comment="Retrieving element text attribute for validation"
                       locator="testApp.inputResult"
                       locatorStrategy="locatorId"
                       name="text">
                <content>You typed: Test</content>
            </attribute>
        </assert>
    </native>

</scenario>