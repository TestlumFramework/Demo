<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Self test for native command: image</description>
        <name>Image native test</name>
    </overview>

    <settings>
        <tags>native</tags>
    </settings>

    <native comment="Start native scripts">
        
        <wait comment="Wait 3 seconds" time="3"/>

       <image comment="Compare full screen" file="compare1.png">
           <fullScreen/>
       </image>

        <image comment="Compare image by locator" file="compare2.png">
            <part locator="loginNative.img"/>
        </image>

        <image comment="Compare part screen" file="compare3.png">
            <part locator="loginNative.googleAuth"/>
        </image>

        <wait comment="Wait for timeout scenario" time="1"/>

    </native>

</scenario>
