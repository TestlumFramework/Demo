<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <name>Assert Equal - General</name>
        <description>Basic test for equal assertion in mobile browser</description>
    </overview>

    <settings>
        <tags>mobilebrowser</tags>
    </settings>

    <include comment="Include login steps" scenario="/ui/includes/login_mobile_browser/scenario.xml"/>

    <mobilebrowser comment="Start MOBILE BROWSER script">

        <var comment="Get Dashboard title" name="dashboardTitle">
            <element>
                <attribute name="innerText"
                           locator="/html/body/div/div/div[2]/main/div/div/h3"
                           locatorStrategy="xpath"/>
            </element>
        </var>

        <assert comment="Check that all values are equal">
            <equal comment="Check 2 same values">
                <content>{{dashboardTitle}}</content>
                <content>Dashboard</content>
            </equal>
        </assert>

    </mobilebrowser>

</scenario>