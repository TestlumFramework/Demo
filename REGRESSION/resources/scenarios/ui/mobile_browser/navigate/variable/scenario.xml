<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <name>Navigate - Variable</name>
        <description>
            This scenario verifies navigate command using variables in mobile browser.

            This scenario validates:
            - path injection
            - locator injection
            - expected value injection
            - dynamic comments usage
        </description>
    </overview>

    <settings>
        <tags>mobilebrowser</tags>
    </settings>

    <include comment="Include login step"
             scenario="/ui/includes/login_mobile_browser/scenario.xml"/>

    <mobilebrowser comment="Start MOBILE BROWSER script">

        <var comment="Navigate command comment"
             name="navigateComment">
            <constant value="Navigate to UI Elements page"/>
        </var>

        <var comment="Wait command comment"
             name="waitComment">
            <constant value="Wait for page load"/>
        </var>

        <var comment="Assert block comment"
             name="assertComment">
            <constant value="Verify page"/>
        </var>

        <var comment="Attribute assert comment"
             name="attributeComment">
            <constant value="Check header text"/>
        </var>

        <var comment="Path variable"
             name="path">
            <constant value="/ui-elements"/>
        </var>

        <var comment="Locator variable"
             name="locator">
            <constant value="uiElements.title"/>
        </var>

        <var comment="Expected value"
             name="expected">
            <constant value="UI Elements"/>
        </var>

        <navigate comment="{{navigateComment}}"
                  command="to"
                  path="{{path}}"/>

        <wait comment="{{waitComment}}" time="2"/>

        <assert comment="{{assertComment}}">
            <attribute comment="{{attributeComment}}"
                       name="innerText"
                       locator="{{locator}}">
                <content>{{expected}}</content>
            </attribute>
        </assert>

    </mobilebrowser>

</scenario>