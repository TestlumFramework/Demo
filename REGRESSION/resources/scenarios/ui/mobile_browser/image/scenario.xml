<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Self test for mobile browser command: Image</description>
        <name>Image mobile browser test</name>
    </overview>

    <settings>
        <tags>mobilebrowser</tags>
    </settings>

    <include comment="Include login steps" scenario="/ui/includes/login_mobile_browser/scenario.xml"/>

    <mobilebrowser comment="Start WEB script">

        <var comment="Check ability to fetch URL of current page and create variable with it" name="url">
            <url/>
        </var>

        <!--Conditions is prescribed in steps with images, so that the tests can be performed both locally,
        and on browser stack, because they have a little difference in phone size-->
        <!--Local is - http://10.0.2.2:3000 / Remote is - http://localhost:3000 / Jenkins is http://mega-test-site -->

        <condition comment="Create condition for check correct work of var 'url'" name="remote"
                   spel="'{{url}}' eq 'http://localhost:3000/dashboard'
                   || '{{url}}' eq 'http://bs-local.com:3000/dashboard'
                   || '{{url}}' eq 'http://mega-test-site/dashboard'"/>

        <condition comment="Create condition for check correct work of var 'url'" name="local"
                   spel="'{{url}}' eq 'http://192.168.0.101:4173/dashboard'"/>

        <navigate comment="Navigate to 'cards' page"
                  command="to" path="/cards"/>

        <wait comment="Wait one second" time="1"/>

        <image comment="Compare full screen(on local)" file="compare1_local.png" highlightDifference="true"
               condition="local">
            <fullScreen percentage="99.9"/>
        </image>

        <image comment="Compare full screen(on remote)" file="compare1_remote.png" highlightDifference="true"
               condition="remote">
            <fullScreen percentage="99.9"/>
        </image>

        <image comment="Compare image by locator" file="compare2.png">
            <part locator="cards.compare"/>
        </image>

        <navigate comment="Navigate to forms tab" command="to" path="/forms"/>

        <wait comment="Wait 1 second" time="1"/>

        <scrollTo comment="Scroll to save button" locator="forms.save"/>

        <wait comment="Wait 1 second" time="1"/>

        <input comment="Input Username field for check image" locator="forms.username"
               value="Image percentage check" highlight="false"/>

        <click comment="Click to save button" locator="forms.save" highlight="false"/>

        <image comment="Compare full screen with percentage less then 100(on local)" file="compare2_local.png"
               condition="local">
            <fullScreen percentage="99.6"/>
        </image>

        <image comment="Compare full screen with percentage less then 100(on remote)" file="compare2_remote.png"
               condition="remote">
            <fullScreen percentage="99.6"/>
        </image>

        <image comment="Compare a part of screen - form table(on local)" file="compare3_local.png"
               condition="local" highlightDifference="true">
            <part locator="forms.form" percentage="99.7"/>
        </image>

        <image comment="Compare a part of screen - form table(on remote)" file="compare3_remote.png"
               condition="remote" highlightDifference="true">
            <part locator="forms.form" percentage="99.9"/>
        </image>

        <clear comment="Clear Username field for check image" locator="forms.username" highlight="false"/>

        <click comment="Click to save button" locator="forms.save" highlight="false"/>

        <image comment="Compare a part of screen with percentage less then 100(on local)" file="compare3_local.png"
               condition="local">
            <part locator="forms.form" percentage="99"/>
        </image>

        <image comment="Compare a part of screen with percentage less then 100(on remote)" file="compare3_remote.png"
               condition="remote">
            <part locator="forms.form" percentage="99"/>
        </image>

        <image comment="Compare a part of screen - 'save' button(on local)" file="compare4_local.png"
               condition="local">
            <part locator="forms.save" percentage="99.9"/>
        </image>

        <image comment="Compare a part of screen - 'save' button(on remote)" file="compare4_remote.png"
               condition="remote">
            <part locator="forms.save" percentage="99.9"/>
        </image>

        <click comment="Click on side bar button" locator="sideBar.sideBarButton"/>

        <wait comment="Wait 1 second" time="1"/>

        <image comment="Compare a part of screen - 'Forms' button(on local)" file="compare5_local.png"
               condition="local">
            <part locator="sideBar.forms"/>
        </image>

        <image comment="Compare a part of screen - 'Forms' button(on remote)" file="compare5_remote.png"
               condition="remote">
            <part locator="sideBar.forms"/>
        </image>

        <wait comment="Wait for timeout scenario" time="1"/>
    </mobilebrowser>

</scenario>
