<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Self test for mobile browser command: Input</description>
        <name>Input mobile browser test</name>
    </overview>

    <settings>
        <tags>mobilebrowser</tags>
    </settings>

    <include comment="Include login steps" scenario="/ui/includes/login_mobile_browser/scenario.xml"/>

    <mobilebrowser comment="Start WEB scripts">

        <var comment="Check ability to fetch URL of current page and create variable with it" name="url">
            <url/>
        </var>

        <!--Conditions is prescribed in steps with images, so that the tests can be performed both locally,
        and on browser stack, because they have a little difference in phone size-->
        <!--Local is - http://10.0.2.2:3000 / Remote is - http://localhost:3000 / Jenkins is http://mega-test-site -->

        <condition comment="Create condition for check correct work of var 'url'" name="remote"
                   spel="'{{url}}' eq 'http://localhost:3000/dashboard'
                   || '{{url}}' eq 'http://bs-local.com:3000/dashboard'
                   || '{{url}}' eq 'http://mega-test-site/dashboard'"/>

        <condition comment="Create condition for check correct work of var 'url'" name="local"
                   spel="'{{url}}' eq 'http://192.168.0.101:4173/dashboard'"/>

        <wait comment="Wait for loading new page 1 second" time="1"/>

        <navigate comment="Navigate to 'Forms' tab"
                  command="to"
                  path="/forms"/>

        <wait comment="Wait for loading new page 1 second" time="1"/>

        <scrollTo comment="Scroll to 'save' button" locator="forms.save"/>

        <input comment="Input username" locator="forms.username" value="Marco"/>

        <input comment="Input Email Address" locator="forms.email" value="reus11@bvb.com"/>

        <input comment="Input Password" locator="forms.password" value="Reus11!reus"/>

        <input comment="Input Password Confirmation" locator="forms.repeatPassword" value="Reus11!reus"/>

        <click comment="Click on save button" locator="forms.save"/>

        <wait comment="Wait for 1 second" time="1"/>

        <image comment="Make sure that fields for input are filled (on local)" file="expected_input_local.png"
               condition="local">
            <fullScreen percentage="99.9"/>
        </image>

        <image comment="Make sure that fields for input are filled (on remote)" file="expected_input_remote.png"
               condition="remote">
            <fullScreen percentage="99.9"/>
        </image>

        <wait comment="Wait for timeout scenario" time="1"/>
    </mobilebrowser>

</scenario>
