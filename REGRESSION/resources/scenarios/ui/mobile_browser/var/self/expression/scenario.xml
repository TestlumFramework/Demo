<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <name>Var - Expression (With Element)</name>
        <description>
            This scenario verifies var expression using real element value in mobile browser.

            Test flow:
            1. Navigate to UI Elements page.
            2. Get title text from page.
            3. Build same value using expression.
            4. Compare both values.
        </description>
    </overview>

    <settings>
        <tags>mobilebrowser</tags>
    </settings>

    <include comment="Include login step"
             scenario="/ui/includes/login_mobile_browser/scenario.xml"/>

    <mobilebrowser comment="Start MOBILE BROWSER script">

        <navigate comment="Navigate to UI Elements page"
                  command="to"
                  path="/ui-elements"/>

        <wait comment="Wait for page load"
              time="2"/>

        <var comment="Get title from page"
             name="pageTitle">
            <element>
                <attribute name="innerText"
                           locator="uiElements.title"/>
            </element>
        </var>

        <var comment="Create expected value using expression"
             name="exprValue">
            <expression value="'UI'.concat(' ').concat('Elements')"/>
        </var>

        <assert comment="Compare page value with expression">
            <equal comment="Compare page value with expression">
                <content>{{pageTitle}}</content>
                <content>{{exprValue}}</content>
            </equal>
        </assert>

    </mobilebrowser>

</scenario>