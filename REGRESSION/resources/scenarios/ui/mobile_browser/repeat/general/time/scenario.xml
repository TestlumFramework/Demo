<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <name>Repeat - Times</name>
        <description>
            Verify repeat execution using times attribute in mobile browser.
        </description>
    </overview>

    <settings>
        <tags>mobilebrowser</tags>
    </settings>

    <include comment="Include login step"
             scenario="/ui/includes/login_mobile_browser/scenario.xml"/>

    <mobilebrowser comment="Start MOBILE BROWSER script">

        <navigate comment="Navigate to UI Elements page"
                  command="to"
                  path="/ui-elements"/>

        <wait comment="Wait for page load"
              time="2"/>

        <clear comment="Clear input before repeat"
               locator="uiElements.hotKeyInput1"/>

        <repeat comment="Repeat increment 3 times"
                times="3">

            <javascript comment="Increment value"
                        file="increment.js"/>

            <wait comment="Stabilize after JS"
                  time="1"/>

        </repeat>

        <assert comment="Verify result after repeat">
            <attribute comment="Check final value"
                       name="value"
                       locator="uiElements.hotKeyInput1">
                <content>3</content>
            </attribute>
        </assert>

    </mobilebrowser>

</scenario>