<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Self test for mobile browser command: Scroll</description>
        <name>Scroll mobile browser test</name>
    </overview>

    <settings active="false">
        <tags>mobilebrowser</tags>
    </settings>

    <include comment="Include login steps" scenario="/ui/includes/login_mobile_browser/scenario.xml"/>

    <mobilebrowser comment="Start WEB scripts">

        <var comment="Check ability to fetch URL of current page and create variable with it" name="url">
            <url/>
        </var>

        <!--Conditions is prescribed in steps with images, so that the tests can be performed both locally,
        and on browser stack, because they have a little difference in phone size-->
        <!--Local is - http://10.0.2.2:3000 / Remote is - http://localhost:3000 / Jenkins is http://mega-test-site -->

        <condition comment="Create condition for check correct work of var 'url'" name="remote"
                   spel="'{{url}}' eq 'http://localhost:3000/dashboard'
                   || '{{url}}' eq 'http://bs-local.com:3000/dashboard'
                   || '{{url}}' eq 'http://mega-test-site/dashboard'"/>

        <condition comment="Create condition for check correct work of var 'url'" name="local"
                   spel="'{{url}}' eq 'http://192.168.0.101:4173/dashboard'"/>

        <wait comment="Wait for loading new page 1 second" time="1"/>

        <scroll comment="Scroll down the page by pixel" type="inner" value="480" direction="down" measure="pixel"
                locator="dashboard.inner"/>

        <wait comment="Wait for 1 second" time="1"/>

        <image comment="Make sure that page was scrolled down (on local)" file="expected_pixel_down_local.png"
               condition="local">
            <fullScreen percentage="99.4"/>
        </image>

        <image comment="Make sure that page was scrolled down (on remote)" file="expected_pixel_down_remote.png"
               condition="remote">
            <fullScreen percentage="99.4"/>
        </image>

        <scroll comment="Scroll up the page by pixel" type="inner" value="350" direction="up" measure="pixel"
                locator="dashboard.inner"/>

        <wait comment="Wait for 1 second" time="1"/>

        <image comment="Make sure that page was scrolled up (on local)" file="expected_pixel_up_local.png"
               condition="local">
            <fullScreen percentage="99.4"/>
        </image>

        <image comment="Make sure that page was scrolled up (on remote)" file="expected_pixel_up_remote.png"
               condition="remote">
            <fullScreen percentage="99.4"/>
        </image>

        <scroll comment="Scroll down the page by percent" type="inner" value="35" direction="down" measure="percent"
                locator="dashboard.inner"/>

        <wait comment="Wait for 1 second" time="1"/>

        <image comment="Make sure that page was scrolled down (on local)" file="expected_percent_down_local.png"
               condition="local">
            <fullScreen percentage="99.9"/>
        </image>

        <image comment="Make sure that page was scrolled down (on remote)" file="expected_percent_down_remote.png"
               condition="remote">
            <fullScreen percentage="99.9"/>
        </image>

        <scroll comment="Scroll up the page by percent" type="inner" value="20" direction="up" measure="percent"
                locator="dashboard.inner"/>

        <wait comment="Wait for 1 second" time="1"/>

        <image comment="Make sure that page was scrolled up (on local)" file="expected_percent_up_local.png"
               condition="local">
            <fullScreen percentage="99.9"/>
        </image>

        <image comment="Make sure that page was scrolled up (on remote)" file="expected_percent_up_remote.png"
               condition="remote">
            <fullScreen percentage="99.9"/>
        </image>

        <wait comment="Wait for timeout scenario" time="1"/>
    </mobilebrowser>

</scenario>
