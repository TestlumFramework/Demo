<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Self test for mobile browser command: DropDown</description>
        <name>DropDown mobile browser test</name>
    </overview>

    <settings active="false">
        <tags>mobilebrowser</tags>
    </settings>

    <include comment="Include login steps" scenario="/ui/includes/login_mobile_browser/scenario.xml"/>

    <mobilebrowser comment="Start WEB scripts">

        <var comment="Check ability to fetch URL of current page and create variable with it" name="url">
            <url/>
        </var>

        <!--Conditions is prescribed in steps with images, so that the tests can be performed both locally,
        and on browser stack, because they have a little difference in phone size-->
        <!--Local is - http://10.0.2.2:3000 / Remote is - http://localhost:3000 / Jenkins is http://mega-test-site -->

        <condition comment="Create condition for check correct work of var 'url'" name="remote"
                   spel="'{{url}}' eq 'http://localhost:3000/dashboard'
                   || '{{url}}' eq 'http://bs-local.com:3000/dashboard'
                   || '{{url}}' eq 'http://mega-test-site/dashboard'"/>

        <condition comment="Create condition for check correct work of var 'url'" name="local"
                   spel="'{{url}}' eq 'http://192.168.0.101:4173/dashboard'"/>

        <navigate comment="Navigate to 'Tables' page"
                  command="to"
                  path="/tables"/>

        <wait comment="Wait for loading new page 1 second" time="1"/>

        <dropDown comment="Selection of one value by 'index'" locator="tables.amount">
            <oneValue type="select" by="index" value="1"/>
        </dropDown>

        <assert comment="Create assert for command's test">
            <attribute comment="Assert for dropDown 'select by index'" name="innerHTML" locator="tables.value1">
                <content>Selected value: 1</content>
            </attribute>
        </assert>

        <wait comment="Wait for 1 second" time="1"/>

        <dropDown comment="Selection of one value by 'value'" locator="tables.amount">
            <oneValue type="select" by="value" value="2"/>
        </dropDown>

        <assert comment="Create assert for command's test">
            <attribute comment="Assert for dropDown 'select by value'" name="innerHTML" locator="tables.value2">
                <content>Selected value: 2</content>
            </attribute>
        </assert>

        <wait comment="Wait for 1 second" time="1"/>

        <dropDown comment="Selection of one value by 'text'" locator="tables.status">
            <oneValue type="select" by="text" value="Active"/>
        </dropDown>

        <wait comment="Wait for 1 second" time="1"/>

        <image comment="Make sure that dropDown 'select by text' command is working(on local)"
               file="expected_by_text_local.png" condition="local">
            <fullScreen percentage="99.9"/>
        </image>

        <image comment="Make sure that dropDown 'select by text' command is working(on remote)"
               file="expected_by_text_remote.png" condition="remote">
            <fullScreen percentage="99.9"/>
        </image>

        <!--        <dropDown comment="Deselection of one value by 'text'" locator="tables.amount">-->
        <!--            <oneValue type="deselect" by="text" value="Active"/>-->
        <!--        </dropDown>-->

        <!--        <wait comment="Wait for timeout scenario" time="1"/>-->
    </mobilebrowser>

</scenario>
