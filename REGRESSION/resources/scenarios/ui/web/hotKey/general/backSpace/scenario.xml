<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <name>HotKey - BackSpace</name>
        <description>
            This scenario verifies hotKey backSpace command.

            Test flow:
            1. Navigate to UI Elements page.
            2. Input initial value into field.
            3. Execute backSpace command.
            4. Verify that last character is removed.

            This scenario validates:
            - backSpace execution
            - correct text modification
        </description>
    </overview>

    <settings>
        <tags>web</tags>
    </settings>

    <include comment="Include login step"
             scenario="/ui/includes/login_web/scenario.xml"/>

    <web comment="Start WEB script">

        <navigate comment="Navigate to UI Elements page"
                  command="to"
                  path="/ui-elements"/>

        <input comment="Fill input field with initial value"
               locator="uiElements.hotKeyInput2"
               value="ABC"/>

        <hotKey comment="Execute backSpace command">
            <backSpace comment="Remove last character"/>
        </hotKey>

        <assert comment="Verify that value is updated after backSpace">
            <attribute comment="Check input value after backSpace"
                       name="value"
                       locator="uiElements.hotKeyInput2">
                <content>AB</content>
            </attribute>
        </assert>

    </web>

</scenario>