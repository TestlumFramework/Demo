<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <name>HotKey - Cut</name>
        <description>
            This scenario verifies hotKey cut command.

            Test flow:
            1. Navigate to UI Elements page.
            2. Input text into field.
            3. Highlight text.
            4. Execute cut command.
            5. Verify that text is removed from input.

            This scenario validates:
            - highlight execution
            - cut execution
            - correct text removal
        </description>
    </overview>

    <settings>
        <tags>web</tags>
    </settings>

    <include comment="Include login step"
             scenario="/ui/includes/login_web/scenario.xml"/>

    <web comment="Start WEB script">

        <navigate comment="Navigate to UI Elements page"
                  command="to"
                  path="/ui-elements"/>

        <input comment="Fill input field with value"
               locator="uiElements.hotKeyInput1"
               value="CUT_TEXT"/>

        <hotKey comment="Highlight text in input">
            <highlight comment="Select full text"
                       locator="uiElements.hotKeyInput1"/>
        </hotKey>

        <hotKey comment="Execute cut command">
            <cut comment="Cut selected text"/>
        </hotKey>

    </web>

</scenario>