<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <name>Var - Generate Alphanumeric</name>
        <description>
            This scenario verifies alphanumeric value generation and input usage.

            Test flow:
            1. Navigate to UI Elements page.
            2. Generate alphanumeric value.
            3. Input generated value.
            4. Verify that input contains generated value.

            This scenario validates:
            - alphanumeric generation
            - variable injection into input
            - correct value application
        </description>
    </overview>

    <settings>
        <tags>web</tags>
    </settings>

    <include comment="Include login steps"
             scenario="/ui/includes/login_web/scenario.xml"/>

    <web comment="Start WEB script">

        <navigate comment="Navigate to UI Elements page"
                  command="to"
                  path="/ui-elements"/>

        <wait comment="Wait for page load"
              time="2"/>

        <var comment="Generate alphanumeric value"
             name="value">
            <generate length="10">
                <alphanumeric/>
            </generate>
        </var>

        <input comment="Input generated value"
               locator="uiElements.hotKeyInput1"
               value="{{value}}"
               highlight="true"/>

        <assert comment="Verify input contains generated value">
            <attribute comment="Check input value"
                       name="value"
                       locator="uiElements.hotKeyInput1">
                <content>{{value}}</content>
            </attribute>
        </assert>

    </web>

</scenario>