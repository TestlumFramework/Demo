<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <name>Var - Element (Present)</name>
        <description>
            This scenario verifies var element with present check.

            Test flow:
            1. Navigate to UI Elements page.
            2. Check element presence.
            3. Store result in variable.
            4. Verify variable value.

            This scenario validates:
            - element presence detection
            - boolean variable storage
        </description>
    </overview>

    <settings>
        <tags>web</tags>
    </settings>

    <include comment="Include login step"
             scenario="/ui/includes/login_web/scenario.xml"/>

    <web comment="Start WEB script">

        <navigate comment="Navigate to UI Elements page"
                  command="to"
                  path="/ui-elements"/>

        <wait comment="Wait for page load"
              time="2"/>

        <var comment="Check element presence"
             name="isPresent">
            <element>
                <present locator="uiElements.title"/>
            </element>
        </var>

        <assert comment="Verify element is present">
            <equal comment="Verify element is present">
                <content>true</content>
                <content>{{isPresent}}</content>
            </equal>
        </assert>

    </web>

</scenario>