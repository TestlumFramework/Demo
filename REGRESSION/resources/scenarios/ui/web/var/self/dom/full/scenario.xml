<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <name>Var - DOM (Full)</name>
        <description>
            This scenario verifies var dom for full page.

            Test flow:
            1. Navigate to UI Elements page.
            2. Capture full DOM.
            3. Verify that DOM is not empty.

            This scenario validates:
            - full DOM extraction
            - variable storage
        </description>
    </overview>

    <settings>
        <tags>web</tags>
    </settings>

    <include comment="Include login step"
             scenario="/ui/includes/login_web/scenario.xml"/>

    <web comment="Start WEB script">

        <navigate comment="Navigate to UI Elements page"
                  command="to"
                  path="/ui-elements"/>

        <wait comment="Wait for page load"
              time="2"/>

        <var comment="Get full DOM"
             name="fullDom">
            <dom/>
        </var>

        <assert comment="Verify DOM is not empty">
            <notEqual comment="Verify DOM is not empty">
                <content>Empty</content>
                <content>{{fullDom}}</content>
            </notEqual>
        </assert>

    </web>

</scenario>