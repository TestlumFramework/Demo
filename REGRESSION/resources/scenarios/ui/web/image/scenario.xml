        <image comment="Compare a part of screen - form table (local image)"
               file="compare5_local.png" condition="local">
            <part locator="forms.form" percentage="99.9"/>
        </image>

        <image comment="Compare a part of screen - form table (remote Jenkins image)"
               file="compare5_remote.jpeg" condition="remote">
            <part locator="forms.form" percentage="90"/>
        </image>

        <clear comment="Clear Username field for check image" locator="forms.username" highlight="false"/>

        <click comment="Click to save button" locator="forms.save" highlight="false"/>

        <image comment="Compare a part of screen with percentage less then 100 (local image)"
               file="compare5_local.png" condition="local">
            <part locator="forms.form" percentage="99"/>
        </image>

        <image comment="Compare a part of screen with percentage less then 100 (remote Jenkins image)"
               file="compare5_remote.jpeg" condition="remote">
            <part locator="forms.form" percentage="95"/>
        </image>

        <wait comment="Wait for timeout scenario" time="1"/>
    </web>

</scenario>
