<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <name>Click - General</name>
        <description>
            This scenario verifies click command functionality.

            Test flow:
            1. Click Sign In button.
            2. Verify Dashboard is displayed.
            3. Repeat click with highlight=false.
            4. Verify Dashboard again.

            This scenario validates:
            - Click execution
            - Highlight behavior
            - UI state change after click
        </description>
    </overview>

    <settings>
        <tags>web</tags>
    </settings>

    <web comment="Start WEB script">

        <wait comment="Wait before click" time="1"/>

        <click comment="Click Sign In button (highlight=true)"
               locator="login.signIn"
               highlight="true"/>

        <wait comment="Wait after click" time="1"/>

        <assert comment="Verify Dashboard is displayed">
            <attribute comment="Check dashboard header"
                       name="innerText"
                       locator="dashboard.title">
                <content>Dashboard</content>
            </attribute>
        </assert>

    </web>

</scenario>