<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Self test for command: Input</description>
        <name>Input test</name>
    </overview>

    <settings active="false">
        <tags>web</tags>
    </settings>

    <include comment="Include login steps" scenario="/ui/includes/login_web/scenario.xml"/>

    <web comment="Start WEB scripts">
        <var comment="Check ability to fetch URL of current page and create variable with it" name="url">
            <url/>
        </var>

        <!--Conditions is prescribed in steps with images, so that the tests can be performed both locally,
        and on Jenkins, because they have difference in size-->
        <!--Local is - http://localhost:3000 / Remote is - http://mega-test-site -->

        <condition comment="Create condition for check correct work of var 'url'" name="remote"
                   spel="'{{url}}' eq 'http://mega-test-site/dashboard'"/>

        <condition comment="Create condition for check correct work of var 'url'" name="local"
                   spel="'{{url}}' eq 'http://localhost:3000/dashboard'"/>

        <wait comment="Wait for loading new page 1 second" time="1"/>

        <click comment="Click on forms button" locator="sideBar.forms"/>

        <wait comment="Wait for loading new page 1 second" time="1"/>

        <var comment="Create var for inner scroll present" name="present">
            <element>
                <present locator="forms.inner"/>
            </element>
        </var>

        <condition comment="Create condition for inner scroll present" name="innerScrollPresent" spel="{{present}}"/>

        <scroll comment="Scroll down the page" type="inner" value="100" measure="percent" locator="forms.inner"
                condition="innerScrollPresent"/>

        <input comment="Input username" value="Marco" locatorStrategy="cssSelector"
               locator="#app > div > div.flex-1.flex.flex-col.overflow-hidden > main > div > div > div.mt-8 > div >
               div > form > div.grid.grid-cols-1.gap-6.mt-4.sm\:grid-cols-2 > div:nth-child(1) > input"/>

        <input comment="Input Email Address" locator="forms.email" value="reus11@bvb.com"/>

        <input comment="Input Password" locator="forms.password" value="Reus11!reus"/>

        <input comment="Input Password Confirmation" locator="forms.repeatPassword" value="Reus11!reus"/>

        <click comment="Click on save button" locatorStrategy="class"
               locator="px-4 py-2 text-gray-200 bg-gray-800 rounded-md hover:bg-gray-700 focus:outline-none focus:bg-gray-700"/>

        <wait comment="Wait for 1 second" time="1"/>

        <image comment="Make sure that fields for input are filled (remote Jenkins image)"
               file="expected_input_local.png" condition="local">
            <fullScreen percentage="99.9"/>
        </image>

        <image comment="Make sure that fields for input are filled (local image)"
               file="expected_input_remote.png" condition="remote">
            <fullScreen percentage="85"/>
        </image>

        <wait comment="Wait for timeout scenario" time="1"/>
    </web>

</scenario>
