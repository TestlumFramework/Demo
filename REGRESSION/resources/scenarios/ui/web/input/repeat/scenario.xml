<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <name>Input - Repeat</name>
        <description>
            This scenario verifies repeated execution of input command.

            Test flow:
            1. Navigate to UI Elements page.
            2. Repeat input execution multiple times.
            3. Verify value after each iteration.

            This scenario validates:
            - repeat execution
            - input stability
            - proper clearing behavior
        </description>
    </overview>

    <settings>
        <tags>web</tags>
    </settings>

    <include comment="Include login step"
             scenario="/ui/includes/login_web/scenario.xml"/>

    <web comment="Start WEB script">

        <navigate comment="Navigate to UI Elements page"
                  command="to"
                  path="/ui-elements"/>

        <wait comment="Wait for page load" time="2"/>

        <repeat comment="Repeat input 3 times"
                times="3">

            <clear comment="Clear input before typing"
                   locator="uiElements.hotKeyInput1"/>

            <input comment="Input value"
                   locator="uiElements.hotKeyInput1"
                   value="REPEAT"
                   highlight="true"/>

            <assert comment="Verify value">
                <attribute comment="Check input value"
                           name="value"
                           locator="uiElements.hotKeyInput1">
                    <content>REPEAT</content>
                </attribute>
            </assert>

        </repeat>

    </web>

</scenario>