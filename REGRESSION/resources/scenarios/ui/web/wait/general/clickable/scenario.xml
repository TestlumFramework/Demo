<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <name>Wait - Clickable (Seconds)</name>
        <description>
            This scenario verifies wait clickable using seconds delay.

            Test flow:
            1. Navigate to UI Elements page.
            2. Set wait time to 2 seconds.
            3. Start delayed action.
            4. Wait until element becomes clickable.
            5. Verify result.

            This scenario validates:
            - seconds-based delay
            - wait clickable behavior
            - async UI execution
        </description>
    </overview>

    <settings>
        <tags>web</tags>
    </settings>

    <include comment="Include login step"
             scenario="/ui/includes/login_web/scenario.xml"/>

    <web comment="Start WEB script for wait clickable">

        <navigate comment="Navigate to UI Elements page"
                  command="to"
                  path="/ui-elements"/>

        <wait comment="Wait for page load"
              time="2"/>

        <input comment="Set wait time to 2 seconds"
               locator="uiElements.waitTime"
               value="2"/>

        <click comment="Start delayed action"
               locator="uiElements.waitStart"/>

        <wait comment="Wait 3 second"
              time="3"/>

        <assert comment="Verify result is visible after wait">
            <present comment="Check result is displayed"
                     locator="uiElements.waitResult"/>
        </assert>

    </web>

</scenario>