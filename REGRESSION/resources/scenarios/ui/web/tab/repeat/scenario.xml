<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <name>Tab - Repeat Variations</name>
        <description>
            This scenario verifies tab opening using repeat with variations.

            Test flow:
            1. Navigate to base page.
            2. Open multiple tabs using repeat variations.
            3. Switch to each tab.
            4. Verify correct content.

            This scenario validates:
            - repeat variations execution
            - dynamic tab opening
            - correct tab switching
            - correct content per tab
        </description>
    </overview>

    <settings>
        <tags>web</tags>
    </settings>

    <include comment="Include login step"
             scenario="/ui/includes/login_web/scenario.xml"/>

    <web comment="Start WEB script">

        <navigate comment="Navigate to Forms page"
                  command="to"
                  path="/forms"/>

        <wait comment="Wait for page load"
              time="2"/>

        <repeat comment="Open tabs from CSV"
                variations="tabRepeat.csv">

            <tab comment="{{tabComment}}">
                <open url="{{url}}"/>
            </tab>

        </repeat>

        <wait comment="Wait after opening tabs"
              time="2"/>

        <tab comment="Switch to tab 2">
            <switch index="2"/>
        </tab>

        <assert comment="Verify UI Elements">
            <attribute comment="Verify UI Elements"
                       name="innerText"
                       locator="uiElements.title">
                <content>UI Elements</content>
            </attribute>
        </assert>

        <tab comment="Switch to tab 3">
            <switch index="3"/>
        </tab>

        <assert comment="Verify Forms">
            <attribute comment="Verify Forms"
                       name="type"
                       locator="forms.username">
                <content>text</content>
            </attribute>
        </assert>

        <tab comment="Switch to tab 4">
            <switch index="4"/>
        </tab>

        <assert comment="Verify UI Elements again">
            <attribute comment="Verify UI Elements again"
                       name="innerText"
                       locator="uiElements.title">
                <content>UI Elements</content>
            </attribute>
        </assert>

    </web>

</scenario>