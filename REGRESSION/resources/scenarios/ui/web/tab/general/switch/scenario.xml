<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <name>Tab - Switch</name>
        <description>
            This scenario verifies switching between browser tabs.

            Test flow:
            1. Navigate to Forms page (tab 1).
            2. Open UI Elements page in new tab (tab 2).
            3. Switch to tab 2 and verify content.
            4. Switch back to tab 1 and verify content.

            This scenario validates:
            - tab switching by index
            - correct tab focus
            - DOM context switching
        </description>
    </overview>

    <settings>
        <tags>web</tags>
    </settings>

    <include comment="Include login step"
             scenario="/ui/includes/login_web/scenario.xml"/>

    <web comment="Start WEB script">

        <navigate comment="Navigate to Forms page"
                  command="to"
                  path="/forms"/>

        <wait comment="Wait for page load"
              time="2"/>

        <tab comment="Open new tab with UI Elements page">
            <open url="/ui-elements"/>
        </tab>

        <wait comment="Wait for tab creation"
              time="2"/>

        <tab comment="Switch to second tab">
            <switch index="2"/>
        </tab>

        <wait comment="Wait after switch"
              time="1"/>

        <assert comment="Verify UI Elements page is active">
            <attribute comment="Check page title"
                       name="innerText"
                       locator="uiElements.title">
                <content>UI Elements</content>
            </attribute>
        </assert>

        <tab comment="Switch back to first tab">
            <switch index="1"/>
        </tab>

        <wait comment="Wait after switch back"
              time="1"/>

        <assert comment="Verify Forms page is active">
            <attribute comment="Check input exists"
                       name="type"
                       locator="forms.username">
                <content>text</content>
            </attribute>
        </assert>

    </web>

</scenario>