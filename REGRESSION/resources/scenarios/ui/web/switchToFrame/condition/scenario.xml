<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <name>SwitchToFrame - Condition</name>
        <description>
            This scenario verifies switchToFrame command using condition.

            Test flow:
            1. Navigate to UI Elements page.
            2. Create false condition → switch should be skipped.
            3. Verify that iframe content is NOT accessible.
            4. Create true condition → switch should execute.
            5. Verify that iframe interaction works.

            This scenario validates:
            - conditional execution
            - skip behavior
            - correct iframe switching
        </description>
    </overview>

    <settings>
        <tags>web</tags>
    </settings>

    <include comment="Include login step"
             scenario="/ui/includes/login_web/scenario.xml"/>

    <web comment="Start WEB script">

        <navigate comment="Navigate to UI Elements page"
                  command="to"
                  path="/ui-elements"/>

        <wait comment="Wait for page load"
              time="2"/>

        <scrollTo comment="Scroll to iframe"
                  locator="uiElements.testFrame"/>

        <wait comment="Wait after scroll"
              time="1"/>


        <condition comment="Create false condition"
                   name="shouldSwitchFalse"
                   spel="false"/>

        <condition comment="Create true condition"
                   name="shouldSwitchTrue"
                   spel="true"/>

        <switchToFrame comment="Try to switch with false condition"
                       locator="uiElements.testFrame"
                       condition="shouldSwitchFalse">

            <click comment="Click to frame button" locator="uiElements.frameButton"/>

        </switchToFrame>


        <assert comment="Verify we are still outside iframe">
            <present comment="Frame button should NOT be accessible"
                     locator="uiElements.frameButton"
                     negative="true"/>
        </assert>


        <switchToFrame comment="Switch with true condition"
                       locator="uiElements.testFrame"
                       condition="shouldSwitchTrue">

            <click comment="Click inside iframe"
                   locator="uiElements.frameButton"/>

            <wait comment="Wait after click"
                  time="1"/>

            <assert comment="Verify result inside iframe">
                <attribute comment="Check result text"
                           name="innerText"
                           locator="uiElements.frameResult">
                    <content>Clicked!</content>
                </attribute>
            </assert>

        </switchToFrame>

    </web>

</scenario>