<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Self test for command: Switch to Frame</description>
        <name>SwitchToFrame test</name>
    </overview>

    <settings active="true">
        <tags>web</tags>
    </settings>

    <include comment="Include login steps" scenario="/ui/includes/login_web/scenario.xml"/>

    <web comment="Start WEB scripts">

        <wait comment="Wait for loading new page 1 second" time="1"/>

        <navigate comment="Navigate to 'UI Elements' tab"
                  command="to"
                  path="/ui-elements"/>

        <wait comment="Wait for loading new page 1 second" time="1"/>
        
        <scrollTo comment="Scroll to video that is in Frame" locator="uiElements.video"/>

        <switchToFrame comment="Open Iframe in the site" locatorStrategy="cssSelector"
                       locator="#app > div > div.flex-1.flex.flex-col.overflow-hidden > main > div > div > div:nth-child(7) > div > div > iframe">

            <wait comment="Wait for loading YouTube video for 3 seconds" time="3"/>

            <click comment="Click on 'play' button on the video" locator="uiElements.play"/>

<!--            <click comment="Click on 'pause' button on the video" locator="uiElements.pause"/>-->

<!--            <assert comment="Make sure that the frame has opened">-->
<!--                <attribute comment="Assert for SwitchToFrame" name="class" locator="uiElements.img">-->
<!--                    <content>branding-img iv-click-target</content>-->
<!--                </attribute>-->
<!--            </assert>-->

        </switchToFrame>

        <wait comment="Wait for timeout scenario" time="1"/>
    </web>

</scenario>