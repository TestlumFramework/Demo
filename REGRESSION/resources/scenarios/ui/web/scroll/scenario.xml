<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Self test for command: Scroll</description>
        <name>Scroll test</name>
    </overview>

    <settings active="true">
        <tags>web</tags>
    </settings>

    <include comment="Include login steps" scenario="/ui/includes/login_web/scenario.xml"/>

    <web comment="Start WEB scripts">
        <var comment="Check ability to fetch URL of current page and create variable with it" name="url">
            <url/>
        </var>

        <!--Conditions is prescribed in steps with images, so that the tests can be performed both locally,
        and on Jenkins, because they have difference in size-->
        <!--Local is - http://localhost:3000 / Remote is - http://mega-test-site -->

        <condition comment="Create condition for check correct work of var 'url'" name="remote"
                   spel="'{{url}}' eq 'http://mega-test-site/dashboard'"/>

        <condition comment="Create condition for check correct work of var 'url'" name="local"
                   spel="'{{url}}' eq 'http://localhost:3000/dashboard'"/>

        <wait comment="Wait for loading new page 1 second" time="1"/>

        <scroll comment="Scroll down the page by pixel" type="inner" value="480" direction="down" measure="pixel"
                locatorStrategy="cssSelector" locator="#app > div > div.flex-1.flex.flex-col.overflow-hidden > main"/>

        <wait comment="Wait for 1 second" time="1"/>

        <assert comment="Make sure that page scrolled down and 'up' button is displayed">
            <attribute comment="Assert for ScrollTo" name="class" locator="dashboard.up">
                <content>to-top</content>
            </attribute>
        </assert>

        <scroll comment="Scroll up the page by pixel" type="inner" value="350" direction="up" measure="pixel"
                locator="dashboard.inner" locatorStrategy="locatorId"/>

        <wait comment="Wait for 2 second" time="2"/>

        <image comment="Make sure that page was scrolled up (remote Jenkins image)"
               file="expected_pixel_remote.png" condition="remote">
            <fullScreen percentage="90"/>
        </image>

        <image comment="Make sure that page was scrolled up (local image)"
               file="expected_pixel_local.png" condition="local">
            <fullScreen percentage="99.4"/>
        </image>

        <var comment="Create constant var for inject to locator" name="var">
            <constant value="main"/>
        </var>

        <scroll comment="Scroll down the page by percent" type="inner" value="35" direction="down" measure="percent"
                locator="#app > div > div.flex-1.flex.flex-col.overflow-hidden > {{var}}" locatorStrategy="cssSelector"/>

        <wait comment="Wait for 1 second" time="1"/>

        <assert comment="Make sure that page scrolled down and 'up' button is displayed">
            <attribute comment="Assert for ScrollTo" name="class" locator="dashboard.up">
                <content>to-top</content>
            </attribute>
        </assert>

        <scroll comment="Scroll up the page by percent" type="inner" value="20" direction="up" measure="percent"
                locator="dashboard.inner"/>

        <wait comment="Wait for 2 second" time="2"/>

        <image comment="Make sure that page was scrolled up (remote Jenkins image)"
               file="expected_percent_remote.png" condition="remote">
            <fullScreen percentage="90"/>
        </image>

        <image comment="Make sure that page was scrolled up (local image)"
               file="expected_percent_local.png" condition="local">
            <fullScreen percentage="99.4"/>
        </image>

        <wait comment="Wait for 1 second" time="1"/>

        <navigate comment="Navigate to cards tab" command="to" path="/cards"/>

        <wait comment="Wait for 1 second" time="1"/>

        <scroll comment="Scroll down the page by percent with page type"
                type="page" direction="down" value="100" measure="percent"/>

        <wait comment="Wait for 2 second" time="2"/>

        <image comment="Make sure that page was scrolled up (remote Jenkins image)"
               file="expected_page_down_remote.png" condition="remote">
            <fullScreen percentage="85"/>
        </image>

        <image comment="Make sure that page was scrolled up (local image)"
               file="expected_page_down_local.png" condition="local">
            <fullScreen percentage="99.9"/>
        </image>

        <wait comment="Wait for 1 second" time="1"/>

        <scroll comment="Scroll up the page by percent with page type"
                type="page" direction="up" value="100" measure="percent"/>

        <wait comment="Wait for 2 second" time="2"/>

        <image comment="Make sure that page was scrolled up (remote Jenkins image)"
               file="expected_page_up_remote.png" condition="remote">
            <fullScreen percentage="85"/>
        </image>

        <image comment="Make sure that page was scrolled up (local image)"
               file="expected_page_up_local.png" condition="local">
            <fullScreen percentage="99.9"/>
        </image>

        <wait comment="Wait for timeout scenario" time="2"/>
    </web>

</scenario>
