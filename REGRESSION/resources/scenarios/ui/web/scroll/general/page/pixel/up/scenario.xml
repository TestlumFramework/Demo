<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <name>Scroll - Page Pixel Up</name>
        <description>
            This scenario verifies page scroll up using pixel measure.

            Test flow:
            1. Navigate to Scroll Test page.
            2. Scroll down page by pixel.
            3. Scroll up page by pixel.
            4. Verify that top element becomes present.

            This scenario validates:
            - page scroll up
            - pixel measure
            - reverse scroll behavior
        </description>
    </overview>

    <settings>
        <tags>web</tags>
    </settings>

    <include comment="Include login step"
             scenario="/ui/includes/login_web/scenario.xml"/>

    <web comment="Start WEB script">

        <navigate comment="Navigate to Scroll Test page"
                  command="to"
                  path="/scroll-test"/>

        <wait comment="Wait for page load"
              time="2"/>

        <scroll comment="Scroll page down by pixel"
                type="page"
                direction="down"
                value="800"
                measure="pixel"/>

        <wait comment="Wait after scroll down"
              time="1"/>

        <scroll comment="Scroll page up by pixel"
                type="page"
                direction="up"
                value="800"
                measure="pixel"/>

        <wait comment="Wait after scroll up"
              time="1"/>

        <assert comment="Verify top element is present after scroll up">
            <present comment="Check page top element"
                     locator="scrollTest.pageTop"/>
        </assert>

    </web>

</scenario>