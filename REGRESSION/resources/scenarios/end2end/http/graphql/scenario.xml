<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Demonstration of the positive GraphQL test</description>
        <name>Positive GraphQL test</name>
    </overview>

    <settings truncateStorages="true">
        <tags>graphql</tags>
    </settings>

    <migrate comment="Migrate test dataset (4 books)"
             alias="MONGO_BOOKS_0"
             name="MONGODB">
        <dataset>mongo_books_patch.bson</dataset>
    </migrate>

    <graphql comment="Check ability to get list of 4 migrated books with POST method"
             alias="MEGA_GQL_APP">
        <post endpoint="/graphql">
            <response code="200" file="expected_2.json"/>
            <body>
                <from file="request_2.json"/>
            </body>
        </post>
    </graphql>

    <graphql comment="Check ability to get list of 4 migrated books with GET method"
             alias="MEGA_GQL_APP">
        <get endpoint="/graphql">
            <response code="200" file="expected_3.json"/>
            <param name="query" data="{ getAllBooks { id author title number } }"/>
        </get>
    </graphql>

    <mongo comment="Checking that 4 books are actually present in DB"
           alias="MONGO_BOOKS_0"
           file="expected_4.json">
        <query>
            {
            find: "mongo_book"
            }
        </query>
    </mongo>

    <graphql comment="Check ability to add one more book via API query (title=Kobzar)"
             alias="MEGA_GQL_APP">
        <post endpoint="/graphql">
            <response code="200" file="expected_5.json"/>
            <body>
                <from file="request_5.json"/>
            </body>
        </post>
    </graphql>

    <graphql comment="Check ability to get previously added book by title"
             alias="MEGA_GQL_APP">
        <post endpoint="/graphql">
            <response code="200" file="expected_6.json"/>
            <body>
                <raw>
                    {
                    "query": "{ getBookByTitle(title: \"Kobzar\") { id author title number } }"
                    }
                </raw>
            </body>
        </post>
    </graphql>

    <mongo comment="Checking that book with title 'Kobzar' was added in DB"
           alias="MONGO_BOOKS_0"
           file="expected_7.json">
        <query>
            {
            find: "mongo_book",
            filter: {
            title: "Kobzar"
            }
            }
        </query>
    </mongo>

    <graphql comment="Check ability to get author and title of all books with GET method"
             alias="MEGA_GQL_APP">
        <get endpoint="/graphql">
            <response code="200" file="expected_8.json"/>
            <param name="query" data="{ getAllBooks { author title } }"/>
        </get>
    </graphql>

    <graphql comment="Check ability to get id and number of book by title 'A Man Called Ove' with POST method"
             alias="MEGA_GQL_APP">
        <post endpoint="/graphql">
            <response code="200" file="expected_9.json"/>
            <body>
                <from file="request_9.json"/>
            </body>
        </post>
    </graphql>

</scenario>