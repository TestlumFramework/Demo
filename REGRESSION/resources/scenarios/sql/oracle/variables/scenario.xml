<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Oracle Test with variables</description>
        <name>Oracle Variables Test</name>
    </overview>

    <settings truncateStorages="true">
        <tags>oracle</tags>
    </settings>

    <var comment="Variable with expected 3 file name"
         name="expected_3">
        <constant value="expected_3"/>
    </var>

    <var comment="Variable with news id"
         name="id">
        <constant value="10"/>
    </var>

    <oracle alias="ORACLE_0"
            comment="Create table"
            file="{{expected_3}}.json">
        <query>
            CREATE TABLE test_news (
            id NUMBER(10) PRIMARY KEY,
            title VARCHAR2(100),
            category VARCHAR2(50)
            )
        </query>
    </oracle>

    <var comment="Variable with expected 7 file name"
         name="expected_7">
        <constant value="expected_7"/>
    </var>

    <var comment="Variable with news title"
         name="title">
        <constant value="New Database Support"/>
    </var>

    <var comment="Variable with news category"
         name="category">
        <constant value="Tech"/>
    </var>

    <oracle alias="ORACLE_0"
            comment="Insert dynamic data to table for news id {{id}}"
            file="{{expected_7}}.json">
        <query>
            INSERT INTO test_news (id, title, category)
            VALUES ({{id}}, '{{title}}', '{{category}}')
        </query>
    </oracle>

    <oracle alias="ORACLE_0"
            comment="Read data from table using variable in WHERE clause"
            file="expected_8.json">
        <query>
            SELECT id AS "id", title AS "title", category AS "category"
            FROM test_news
            WHERE id = {{id}}
        </query>
    </oracle>

    <oracle alias="ORACLE_0"
            comment="Drop table to clean up environment"
            file="expected_9.json">
        <query>
            DROP TABLE test_news
        </query>
    </oracle>

</scenario>