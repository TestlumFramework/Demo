<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Oracle CRUD Operations Test</description>
        <name>Oracle Basic CRUD Test</name>
    </overview>

    <settings truncateStorages="true">
        <tags>oracle</tags>
    </settings>

    <oracle alias="ORACLE_0"
            comment="Execute CREATE TABLE command"
            file="expected_1.json">
        <query>
            CREATE TABLE test_users (
            id NUMBER(10),
            username VARCHAR2(50) NOT NULL,
            user_role VARCHAR2(20),
            PRIMARY KEY (id))
        </query>
    </oracle>

    <oracle alias="ORACLE_0"
            comment="Execute INSERT command"
            file="expected_2.json">
        <query>
            INSERT INTO test_users (id, username, user_role)
            VALUES (101, 'john_doe', 'ADMIN')
        </query>
    </oracle>

    <oracle alias="ORACLE_0"
            comment="Execute SELECT command - verify inserted data"
            file="expected_3.json">
        <query>
            SELECT id AS "id", username AS "username", user_role AS "role"
            FROM test_users
            WHERE id = 101
        </query>
    </oracle>

    <oracle alias="ORACLE_0"
            comment="Execute UPDATE command"
            file="expected_4.json">
        <query>
            UPDATE test_users
            SET user_role = 'SUPER_ADMIN'
            WHERE id = 101
        </query>
    </oracle>

    <oracle alias="ORACLE_0"
            comment="Execute SELECT command - verify updated data"
            file="expected_5.json">
        <query>
            SELECT id AS "id", username AS "username", user_role AS "role"
            FROM test_users
            WHERE id = 101
        </query>
    </oracle>

    <oracle alias="ORACLE_0"
            comment="Execute DELETE command"
            file="expected_6.json">
        <query>
            DELETE FROM test_users
            WHERE id = 101
        </query>
    </oracle>

    <oracle alias="ORACLE_0"
            comment="Execute SELECT command - verify data is deleted"
            file="expected_7.json">
        <query>
            SELECT id AS "id", username AS "username", user_role AS "role"
            FROM test_users
            WHERE id = 101
        </query>
    </oracle>

    <oracle alias="ORACLE_0"
            comment="Execute DROP TABLE command"
            file="expected_8.json">
        <query>
            DROP TABLE test_users
        </query>
    </oracle>

</scenario>