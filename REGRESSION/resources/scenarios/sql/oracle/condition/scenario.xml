<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Oracle conditional execution check</description>
        <name>Oracle Condition Test</name>
    </overview>

    <settings truncateStorages="true">
        <tags>oracle</tags>
    </settings>

    <oracle alias="ORACLE_0"
            comment="Create table for condition test"
            file="expected_1.json">
        <query>
            CREATE TABLE condition_test (
            id NUMBER(10) PRIMARY KEY,
            data_value VARCHAR2(50)
            )
        </query>
    </oracle>

    <condition comment="True condition to insert test data into table" name="CONDITION_TRUE" spel="true"/>

    <oracle alias="ORACLE_0"
            comment="Insert data to table"
            file="expected_3.json"
            condition="{{CONDITION_TRUE}}">
        <query>INSERT INTO condition_test (id, data_value) VALUES (99, 'INITIAL_DATA')</query>
    </oracle>

    <oracle alias="ORACLE_0"
            comment="Read data from table - verify inserted data"
            file="expected_4.json">
        <query>SELECT id AS "id", data_value AS "data_value" FROM condition_test WHERE id = 99</query>
    </oracle>

    <oracle alias="ORACLE_0"
            comment="Attempt to delete with condition=false"
            condition="false"
            file="expected_5.json">
        <query>DELETE_NOT_EXIST FROM condition_test WHERE id = 99</query>
    </oracle>

    <var comment="Variable with true condition"
         name="TRUE_CONDITION">
        <expression value="true"/>
    </var>
    
    <oracle alias="ORACLE_0"
            comment="Read data from table - verify data was NOT deleted"
            condition="{{TRUE_CONDITION}}"
            file="expected_7.json">
        <query>SELECT id AS "id", data_value AS "data_value" FROM condition_test WHERE id = 99</query>
    </oracle>

    <oracle alias="ORACLE_0"
            comment="Drop table to clean up environment"
            file="expected_8.json">
        <query>DROP TABLE condition_test</query>
    </oracle>

</scenario>