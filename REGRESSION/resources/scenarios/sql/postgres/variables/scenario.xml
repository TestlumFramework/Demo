<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>PostgreSQL Test with variables</description>
        <name>Postgres Variables Test</name>
    </overview>

    <settings truncateStorages="true">
        <tags>postgres</tags>
    </settings>

    <var comment="Variable with expected 3 file"
         name="expected_3">
        <constant value="expected_3"/>
    </var>

    <var comment="Variable with news id"
         name="id">
        <constant value="10"/>
    </var>
    
    <postgres alias="POSTGRES_0"
              comment="Create table and clear previous data for the current ID"
              file="{{expected_3}}.json">
        <query>
            CREATE TABLE IF NOT EXISTS test_news (
            id INT PRIMARY KEY,
            title VARCHAR(100),
            category VARCHAR(50)
            );
        </query>
        <query>DELETE FROM test_news WHERE id = {{id}};</query>
    </postgres>

    <var comment="Variable with expected 7 file"
         name="expected_7">
        <constant value="expected_7"/>
    </var>

    <var comment="Variable with news title"
         name="title">
        <constant value="New Database Support"/>
    </var>

    <var comment="Variable with news category"
         name="category">
        <constant value="Tech"/>
    </var>

    <postgres alias="POSTGRES_0"
              comment="Insert dynamic data to table for user id {{id}}"
              file="{{expected_7}}.json">
        <query>
            INSERT INTO test_news (id, title, category)
            VALUES ({{id}}, '{{title}}', '{{category}}');
        </query>
    </postgres>

    <postgres alias="POSTGRES_0"
              comment="Read data from table using variations"
              file="expected_8.json">
        <query>SELECT id, title, category FROM test_news WHERE id = {{id}};</query>
    </postgres>

</scenario>