<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Self test for command: Repeat</description>
        <name>Repeat general test</name>
    </overview>

    <settings>
        <variations>repeat_inject_variations.csv</variations>
        <tags>repeat</tags>
    </settings>

    <var comment="Initialize result accumulator with constant value 0 before repeat starts" name="result">
        <constant value="0"/>
    </var>

    <repeat comment="Iterate over variation values and accumulate their sum into result" variations="repeat_variations.csv">
        <var comment="Add current variation value {{a}} to accumulated result" name="result">
            <expression value="{{result}} + {{a}}"/>
        </var>
    </repeat>

    <assert comment="Verify that result equals the sum of all variation values after repeat completes">
        <equal comment="result should equal 6">
            <content>{{result}}</content>
            <content>6</content>
        </equal>
        <notEqual comment="result should not equal 0">
            <content>{{result}}</content>
            <content>0</content>
        </notEqual>
        <notEqual comment="result should not equal an incorrect sum of 7">
            <content>{{result}}</content>
            <content>7</content>
        </notEqual>
    </assert>

    <repeat comment="{{comment}}" times="1" condition="{{condition}}">
        <var comment="Add value to accumulated result" name="result">
            <expression value="{{result}} + 1"/>
        </var>
    </repeat>

    <var comment="Create variable for comment injecting" name="commentVar">
        <constant value="Variable comment for injecting in repeat"/>
    </var>

    <var comment="Create variable for condition injecting" name="conditionVar">
        <expression value="1 eq 1"/>
    </var>

    <repeat comment="{{commentVar}}" times="1" condition="{{conditionVar}}">
        <var comment="Add value to accumulated result" name="result">
            <expression value="{{result}} +1"/>
        </var>
    </repeat>
</scenario>