<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Self test for Include command with condition</description>
        <name>Include with condition</name>
    </overview>

    <settings>
        <tags>include</tags>
    </settings>

    <condition comment="Create false condition" name="falseCondition" spel="1 eq 2"/>

    <include comment="Include test scenario with variations" scenario="include/condition/included/scenario.xml"/>

    <assert comment="Check variable from included scenario value">
        <equal comment="Ensure variable has correct value">
            <content>{{theBestTool}}</content>
            <content>Testlum</content>
        </equal>
    </assert>

    <include comment="Include test scenario with false condition" scenario="include/condition/not_included/scenario.xml" condition="falseCondition"/>

<!--  WRONG! - include should not work with the false condition-->
    <assert comment="Check WRONG variable from included scenario value">
        <equal comment="Currently variable has incorrect value">
            <content>{{theBestTool}}</content>
            <content>ShouldNotBeIncluded</content>
        </equal>
    </assert>

</scenario>