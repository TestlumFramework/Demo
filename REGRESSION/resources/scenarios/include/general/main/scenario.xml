<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Self test for Include command</description>
        <name>Variables Include</name>
    </overview>

    <settings active="false">
        <tags>include-self</tags>
    </settings>

    <include comment="Include test scenario with variable" scenario="include/general/included/scenario.xml"/>

    <assert comment="Assert value from var">
        <equal comment="Check constant variable value from included scenario">
            <content>{{bestTool}}</content>
            <content>Testlum</content>
        </equal>
    </assert>

    <var comment="Create var for currentTime to compare with variable 'time' from included scenario" name="currentTime">
        <expression value="new java.text.SimpleDateFormat('yyyy-MM-dd').format(new java.util.Date())"/>
    </var>

    <assert comment="Assert value from expression var">
        <equal comment="Check expression variable value from included scenario">
            <content>{{time}}</content>
            <content>{{currentTime}}</content>
        </equal>
    </assert>

</scenario>