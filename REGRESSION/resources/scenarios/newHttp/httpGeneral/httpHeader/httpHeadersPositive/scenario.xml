<scenario xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <name>Headers Positive</name>
        <description>
            This scenario verifies request and response header validation for HTTP API.

            Test flow includes:
            1. Send request with required headers.
            2. Verify response status = 200.
            3. Validate response body.
            4. Validate response headers.

            This scenario validates:
            - Request header passing
            - Server-side request header validation
            - Response header validation
            - Successful header processing
        </description>
        <developer>Vadym Kostenko</developer>
    </overview>

    <settings truncateStorages="true">
        <tags>httpGeneral</tags>
    </settings>

    <http comment="Step 1-4. Send request with headers and validate response headers"
          alias="MEGA_APP">
        <post endpoint="/api/test/entities/headers">
            <response code="200" file="expected_1.json"/>
            <header name="X-Test-Request-Id" data="req-123"/>
            <header name="X-Test-Client" data="Testlum"/>
            <header name="X-Test-Mode" data="regression"/>

            <header name="X-Validated-Request-Id" data="req-123"/>
            <header name="X-Validated-Client" data="Testlum"/>
            <header name="X-Validated-Mode" data="regression"/>
            <header name="X-Header-Validation" data="SUCCESS"/>
        </post>
    </http>

</scenario>