    <var comment="PostgreSQL query with single column" name="postgresQuery">
        <sql dbType="POSTGRES" alias="POSTGRES_0">
            <query>
                SELECT id
                FROM news
                WHERE newsname='News1';
            </query>
        </sql>
    </var>

    <var comment="MySQL query with single column" name="mysqlQuery">
        <sql dbType="MYSQL" alias="MYSQL_0">
            <query>
                SELECT id
                FROM news
                WHERE newsname='News1';
            </query>
        </sql>
    </var>

    <var comment="Oracle query with single column" name="oracleQuery">
        <sql dbType="ORACLE" alias="ORACLE_0">
            <query>
                SELECT newsnumber
                FROM news
                WHERE newsname = 'Ukraine'
            </query>
        </sql>
    </var>

    <var comment="Clickhouse query with single column" name="clickhouseQuery">
        <sql dbType="CLICKHOUSE" alias="CLICKHOUSE_0">
            <query>
                SELECT database
                FROM system.parts
                WHERE table = 'news'
            </query>
        </sql>
    </var>

</scenario>