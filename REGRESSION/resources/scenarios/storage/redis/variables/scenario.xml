<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Redis Test with variables</description>
        <name>Redis Variables Test</name>
    </overview>

    <settings truncateStorages="true">
        <tags>redis</tags>
    </settings>

    <var comment="Variable with expected 3 file"
         name="expected_3">
        <constant value="expected_3"/>
    </var>

    <var comment="Variable with news id"
         name="id">
        <constant value="10"/>
    </var>

    <redis alias="REDIS_0"
           comment="Clear previous data for the current ID"
           file="{{expected_3}}.json">
        <query>
            <command>DEL</command>
            <arg>test_news:{{id}}</arg>
        </query>
    </redis>

    <var comment="Variable with expected 7 file"
         name="expected_7">
        <constant value="expected_7"/>
    </var>

    <var comment="Variable with news title"
         name="title">
        <constant value="New Database Support"/>
    </var>

    <var comment="Variable with news category"
         name="category">
        <constant value="Tech"/>
    </var>

    <redis alias="REDIS_0"
           comment="Insert dynamic data to hash for news id {{id}}"
           file="{{expected_7}}.json">
        <query>
            <command>HSET</command>
            <arg>test_news:{{id}}</arg>
            <arg>title</arg>
            <arg>{{title}}</arg>
            <arg>category</arg>
            <arg>{{category}}</arg>
        </query>
    </redis>

    <redis alias="REDIS_0"
           comment="Read data from hash using variables"
           file="expected_8.json">
        <query>
            <command>HGETALL</command>
            <arg>test_news:{{id}}</arg>
        </query>
    </redis>

</scenario>