<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Redis conditional execution check</description>
        <name>Redis Condition Test</name>
    </overview>

    <settings truncateStorages="true">
        <tags>redis</tags>
    </settings>

    <redis alias="REDIS_0"
           comment="Clean up specific key before test"
           file="expected_1.json">
        <query>
            <command>DEL</command>
            <arg>condition_test:99</arg>
        </query>
    </redis>

    <condition comment="True condition to insert test data into table" name="CONDITION_TRUE" spel="true"/>

    <redis alias="REDIS_0"
           comment="Insert data to hash"
           file="expected_3.json"
           condition="{{CONDITION_TRUE}}">
        <query>
            <command>HSET</command>
            <arg>condition_test:99</arg>
            <arg>data_value</arg>
            <arg>INITIAL_DATA</arg>
        </query>
    </redis>

    <redis alias="REDIS_0"
           comment="Read data from hash - verify inserted data"
           file="expected_4.json">
        <query>
            <command>HGETALL</command>
            <arg>condition_test:99</arg>
        </query>
    </redis>

    <redis alias="REDIS_0"
           comment="Attempt to delete with condition=false"
           condition="false"
           file="expected_5.json">
        <query>
            <command>FAKE_DELETE</command>
            <arg>condition_test:99</arg>
        </query>
    </redis>

    <redis alias="REDIS_0"
           comment="Read data from hash - verify data was NOT deleted"
           condition="true"
           file="expected_6.json">
        <query>
            <command>HGETALL</command>
            <arg>condition_test:99</arg>
        </query>
    </redis>

    <redis alias="REDIS_0"
           comment="Clean up specific key after test"
           file="expected_7.json">
        <query>
            <command>DEL</command>
            <arg>condition_test:99</arg>
        </query>
    </redis>

</scenario>