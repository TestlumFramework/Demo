<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>RabbitMQ Testing with Variations</description>
        <name>RabbitMQ Variations Test</name>
    </overview>

    <settings truncateStorages="true">
        <variations>rabbit_with_variations_test_data.csv</variations>
        <tags>rabbit</tags>
    </settings>

    <!--  XSD validation error in injection into alias  -->
    <rabbit alias="RABBIT_0"
            comment="Rabbit send and receive using variations: {{testDescription}}">
        <send routingKey="{{queueName}}" correlationId="{{queueName}}">
            <value>
                [ {
                "city": "{{city}}",
                "temperature": "{{temp}}"
                } ]
            </value>
        </send>

        <receive queue="{{queueName}}"
                 timeoutMillis="4000">
            <value>
                [ {
                "message" : [ {
                "city" : "{{city}}",
                "temperature" : "{{temp}}"
                } ],
                "correlationId" : "{{queueName}}",
                "headers" : { }
                } ]
            </value>
        </receive>

        <send routingKey="{{queueName}}">
<!--            <file>{{body_4}}.json           XSD validation error</file>-->
<!--            <file>body_4_1.json             XSD validation</file>-->
            <file>body_4.json</file>
        </send>

        <receive queue="{{queueName}}"
                 timeoutMillis="4000">
            <file>{{expected_5}}.json</file>
        </receive>

    </rabbit>
</scenario>