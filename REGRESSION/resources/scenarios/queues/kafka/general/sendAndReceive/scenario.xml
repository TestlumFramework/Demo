<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Kafka Self Tests: Send and Receive</description>
        <name>Kafka Self Send and Receive</name>
    </overview>

    <settings truncateStorages="true">
        <tags>kafka</tags>
    </settings>

    <kafka alias="QUEUE" comment="Kafka send and receive with value">
        <send correlationId="1" topic="weather">
            <value>
                [ {
                "city": "New York",
                "temperature": 1,
                "condition": "sunny",
                "timestamp": 1650762900
                } ]
            </value>
        </send>

        <receive commit="true"
                 timeoutMillis="4000"
                 topic="weather">
            <value>
                [ {
                "key" : null,
                "value" : [ {
                "city" : "New York",
                "temperature" : 1,
                "condition" : "sunny",
                "timestamp" : 1650762900
                } ],
                "correlationId" : "1",
                "headers" : { }
                } ]
            </value>
        </receive>
    </kafka>


    <kafka alias="QUEUE" comment="Kafka send and receive with file">
        <send correlationId="1"
              topic="weather">
            <file>body_5.json</file>
        </send>

        <receive commit="true"
                 timeoutMillis="4000"
                 topic="weather">
            <file>expected_6.json</file>
        </receive>
    </kafka>
</scenario>