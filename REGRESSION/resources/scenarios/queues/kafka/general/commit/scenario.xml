<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Kafka Self Testing: Manual Commit Behaviour</description>
        <name>Kafka Commit Test</name>
    </overview>

    <settings truncateStorages="true">
        <tags>kafka</tags>
    </settings>

    <kafka alias="KAFKA_WITH_REDUCED_POLL_INVERVAL"
           comment="Kafka send and receive event without committing offest">

        <receive topic="weather">
            <value>
                []
            </value>
        </receive>

        <send topic="weather">
            <value>
                [ {
                "city": "Odessa",
                "temperature": 18
                } ]
            </value>
        </send>
    </kafka>

    <kafka alias="KAFKA_WITH_REDUCED_POLL_INVERVAL"
           comment="Kafka send and receive event without committing offest">

        <receive commit="false"
                 timeoutMillis="4000"
                 topic="weather">
            <file>expected_5.json</file>
        </receive>

<!--        Error: manual committing is not working properly with a single <kafka> command -->

<!--        <receive commit="true"-->
<!--                 timeoutMillis="4000"-->
<!--                 topic="weather">-->
<!--            <file>expected_4.json</file>-->
<!--        </receive>-->

<!--        <receive timeoutMillis="4000"-->
<!--                 topic="weather">-->
<!--            <value>[]</value>-->
<!--        </receive>-->

    </kafka>

    <kafka alias="KAFKA_WITH_REDUCED_POLL_INVERVAL"
           comment="Try to receive event under uncommitted offset">
        <receive commit="true"
                 timeoutMillis="4000"
                 topic="weather">
            <file>expected_7.json</file>
        </receive>

        <receive timeoutMillis="4000"
                 topic="weather">
            <value>[]</value>
        </receive>

    </kafka>

</scenario>