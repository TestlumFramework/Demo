<scenario xmlns="http://www.knubisoft.com/testlum/testing/model/scenario"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://www.knubisoft.com/testlum/testing/model/scenario scenario.xsd">

    <overview>
        <description>Kafka with Conditions Testing</description>
        <name>Kafka Condition Test</name>
    </overview>

    <settings truncateStorages="true">
        <tags>kafka</tags>
    </settings>

    <kafka alias="QUEUE"
           comment="Check that topic is empty initially">
        <receive commit="true"
                 timeoutMillis="4000"
                 topic="weather">
            <value>[]</value>
        </receive>
    </kafka>

    <kafka alias="QUEUE"
           comment="Send message to topic with false condition"
           condition="false">
        <send topic="weather">
            <value>
                [ {
                "city": "Lviv",
                "temperature": 10
                } ]
            </value>
        </send>
    </kafka>

    <var comment="True condition to test injecting var into condition attribute"
         name="TRUE_CONDITION">
        <constant value="true"/>
    </var>

    <kafka alias="QUEUE"
           comment="Send valid message with true condition"
           condition="{{TRUE_CONDITION}}">
        <send topic="weather">
            <value>
                [ {
                "city": "Kyiv",
                "temperature": 15
                } ]
            </value>
        </send>
    </kafka>

    <kafka alias="QUEUE"
           comment="Unconditionally verify that ONLY the true condition message was sent">
        <receive commit="true"
                 timeoutMillis="4000"
                 topic="weather">
            <value>
                [ {
                "city": "Kyiv",
                "temperature": 15
                } ]
            </value>
        </receive>
    </kafka>

</scenario>